const Database = require('better-sqlite3');
const path = require('path');
const crypto = require('crypto');

const db = new Database(path.join(__dirname, '..', 'database.sqlite'));

// Helper to parse JSON fields
function parseJSONField(value) {
    if (!value) return [];
    try {
        return JSON.parse(value);
    } catch {
        return [];
    }
}

// User functions
function getUsers() {
    return db.prepare("SELECT * FROM users").all();
}

function findOrCreateUserByEmail(email, termsAgreedAt = null) {
    let user = db.prepare("SELECT * FROM users WHERE email = ?").get(email);
    if (!user) {
        const id = crypto.randomUUID();
        const agreedAt = termsAgreedAt || new Date().toISOString();
        db.prepare(`
            INSERT INTO users (id, email, createdAt, reviewIds, savedSchools, followedSchools, savedReviewIds, termsAgreedAt)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        `).run(id, email, new Date().toISOString(), '[]', '[]', '[]', '[]', agreedAt);
        user = db.prepare("SELECT * FROM users WHERE id = ?").get(id);
    }
    return user;
}

function getUserById(userId) {
    return db.prepare("SELECT * FROM users WHERE id = ?").get(userId);
}

function addReviewToUser(userId, reviewId) {
    const user = getUserById(userId);
    if (user) {
        const reviewIds = parseJSONField(user.reviewIds);
        if (!reviewIds.includes(reviewId)) {
            reviewIds.push(reviewId);
            db.prepare("UPDATE users SET reviewIds = ? WHERE id = ?").run(JSON.stringify(reviewIds), userId);
        }
    }
}

function removeReviewFromUser(userId, reviewId) {
    const user = getUserById(userId);
    if (user) {
        const reviewIds = parseJSONField(user.reviewIds).filter(id => id !== reviewId);
        db.prepare("UPDATE users SET reviewIds = ? WHERE id = ?").run(JSON.stringify(reviewIds), userId);
    }
}

