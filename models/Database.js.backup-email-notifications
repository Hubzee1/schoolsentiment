// School following functions
function addFollowedSchool(userId, schoolName) {
    const user = getUserById(userId);
    if (user) {
        let followedSchools = [];
        try {
            followedSchools = JSON.parse(user.followedSchools || '[]');
        } catch(e) { followedSchools = []; }
        if (!followedSchools.includes(schoolName)) {
            followedSchools.push(schoolName);
            db.prepare("UPDATE users SET followedSchools = ? WHERE id = ?").run(JSON.stringify(followedSchools), userId);
            return true;
        }
    }
    return false;
}

function removeFollowedSchool(userId, schoolName) {
    const user = getUserById(userId);
    if (user) {
        let followedSchools = [];
        try {
            followedSchools = JSON.parse(user.followedSchools || '[]');
        } catch(e) { followedSchools = []; }
        const newFollowed = followedSchools.filter(s => s !== schoolName);
        db.prepare("UPDATE users SET followedSchools = ? WHERE id = ?").run(JSON.stringify(newFollowed), userId);
        return true;
    }
    return false;
}

function getFollowedSchools(userId) {
    const user = getUserById(userId);
    if (user && user.followedSchools) {
        try {
            return JSON.parse(user.followedSchools);
        } catch(e) { return []; }
    }
    return [];
}
