<%- include('partials/header') %>

<div class="bg-[#fefbf0] text-slate-900 antialiased min-h-screen relative overflow-x-hidden">
  
  <!-- FAINT BACKGROUND WALLPAPER -->
  <div class="absolute inset-0 opacity-[0.008] pointer-events-none select-none z-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full min-h-screen" viewBox="0 0 1200 1000" preserveAspectRatio="xMidYMid slice">
      <g stroke="#000" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <g transform="translate(650, 180)"><circle cx="90" cy="90" r="80"/><path d="M60 75 Q75 60 90 75 M100 75 Q115 60 130 75" stroke-width="14"/><path d="M50 105 Q90 150 130 105 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 132 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
      </g>
    </svg>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-4 py-12">
    <div class="bg-white rounded-xl shadow-sm border p-8">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-slate-900">Edit School Profile</h1>
        <a href="/school/<%= encodeURIComponent(schoolName) %>" class="text-indigo-600 hover:underline text-sm">← Back to school</a>
      </div>
      
      <form action="/update-school-profile" method="POST" class="space-y-6">
        <input type="hidden" name="schoolName" value="<%= schoolName %>">
        
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">School Name</label>
          <input type="text" value="<%= schoolName %>" disabled class="w-full px-4 py-2 bg-slate-100 border border-slate-300 rounded-lg text-slate-500">
          <p class="text-xs text-slate-400 mt-1">School name cannot be changed</p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Work Phone</label>
          <input type="tel" name="workPhone" value="<%= workPhone || '' %>" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
          <p class="text-xs text-slate-400 mt-1">Contact number for the school (optional)</p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Primary Website</label>
          <input type="url" name="primaryWebsite" value="<%= primaryWebsite || '' %>" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
          <p class="text-xs text-slate-400 mt-1">School website URL (optional)</p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Contact Email (Public)</label>
          <input type="email" name="contactEmail" value="<%= contactEmail || '' %>" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
          <p class="text-xs text-slate-400 mt-1">Public-facing email for school inquiries (optional, different from your login email)</p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">School Description</label>
          <textarea name="schoolDescription" rows="5" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" placeholder="Tell us about your school..."><%= schoolDescription || '' %></textarea>
          <p class="text-xs text-slate-400 mt-1">A short description of your school (optional)</p>
        </div>
        
        <div class="pt-4 flex gap-3">
          <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 transition font-medium">Save Changes</button>
          <a href="/school/<%= encodeURIComponent(schoolName) %>" class="bg-gray-200 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-300 transition font-medium">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
