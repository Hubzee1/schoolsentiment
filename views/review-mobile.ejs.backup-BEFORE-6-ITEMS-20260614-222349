<script>
// School autocomplete
const schoolInput = document.getElementById('schoolName');
const autocompleteResults = document.getElementById('autocompleteResults');
let allSchools = [];

fetch('/api/schools')
    .then(response => response.json())
    .then(schools => {
        allSchools = schools;
    });

if (schoolInput) {
    schoolInput.addEventListener('input', function() {
        const query = this.value.trim();
        if (query.length < 2) {
            autocompleteResults.style.display = 'none';
            return;
        }
        const matches = allSchools.filter(s => s.name.toLowerCase().includes(query.toLowerCase()) || s.town.toLowerCase().includes(query.toLowerCase())).slice(0,7);
        if (!matches.length) {
            autocompleteResults.style.display = 'none';
            return;
        }
        let html = '';
        matches.forEach(s => {
            html += `<div class="autocomplete-item" style="padding: 12px 16px; cursor: pointer; border-bottom: 1px solid #f1f5f9;" data-school-name="${s.name.replace(/'/g, "\\'")}">
                        <div style="font-weight: 600; color: #0f172a; margin-bottom: 4px;">${s.name}</div>
                        <div style="font-size: 0.75rem; color: #64748b;">${s.town} • ${s.postcode}</div>
                    </div>`;
        });
        autocompleteResults.innerHTML = html;
        autocompleteResults.style.display = 'block';
    });

    autocompleteResults.addEventListener('click', function(e) {
        const item = e.target.closest('.autocomplete-item');
        if (item) {
            schoolInput.value = item.getAttribute('data-school-name');
            autocompleteResults.style.display = 'none';
        }
    });

    document.addEventListener('click', function(e) {
        if (!schoolInput.contains(e.target) && !autocompleteResults.contains(e.target)) {
            autocompleteResults.style.display = 'none';
        }
    });
}

// Rating faces
document.querySelectorAll('.rating-face').forEach(btn => {
    btn.addEventListener('click', function() {
        const category = this.dataset.category;
        const value = this.dataset.value;
        
        document.querySelectorAll(`.rating-face[data-category="${category}"]`).forEach(b => {
            b.classList.remove('bg-indigo-100', 'ring-2', 'ring-indigo-500', 'ring-offset-2');
        });
        
        this.classList.add('bg-indigo-100', 'ring-2', 'ring-indigo-500', 'ring-offset-2');
        
        let inputId = '';
        if (category === 'teaching') inputId = 'teachingRating';
        else if (category === 'facilities') inputId = 'facilitiesRating';
        else if (category === 'pastoral') inputId = 'pastoralRating';
        else if (category === 'extra') inputId = 'extraRating';
        else if (category === 'sen') inputId = 'senRating';
        else if (category === 'meals') inputId = 'mealsRating';
        
        document.getElementById(inputId).value = value;
    });
});

// Recommend options
document.querySelectorAll('.recommend-option').forEach(btn => {
    btn.addEventListener('click', function() {
        const value = this.dataset.value;
        document.getElementById('recommend').value = value;
        
        document.querySelectorAll('.recommend-option').forEach(b => {
            b.classList.remove('bg-indigo-600', 'text-white');
            b.classList.add('bg-white', 'text-slate-700');
        });
        this.classList.remove('bg-white', 'text-slate-700');
        this.classList.add('bg-indigo-600', 'text-white');
        
        document.getElementById('recommendError').classList.add('hidden');
    });
});

// Year validation
const yearFrom = document.getElementById('yearFrom');
const yearTo = document.getElementById('yearTo');
const yearError = document.getElementById('yearError');

function validateYears() {
    if (yearFrom.value && yearTo.value && parseInt(yearTo.value) < parseInt(yearFrom.value)) {
        yearError.classList.remove('hidden');
        return false;
    }
    yearError.classList.add('hidden');
    return true;
}

yearFrom.addEventListener('change', validateYears);
yearTo.addEventListener('change', validateYears);

// Form validation
document.getElementById('reviewForm').addEventListener('submit', function(e) {
    if (!document.getElementById('recommend').value) {
        e.preventDefault();
        document.getElementById('recommendError').classList.remove('hidden');
        return;
    }
    if (!validateYears()) {
        e.preventDefault();
        return;
    }
});
</script>

