      </g>
    </svg>
  </div>

  <div class="relative z-10">

<main class="max-w-5xl mx-auto px-4 py-4">
    
    <nav class="text-xs text-slate-500 mb-4 flex flex-wrap gap-1">
        <a href="/" class="hover:underline">Home</a>
        <span>&gt;</span>
        <span class="text-slate-800 font-medium">Write Your Review</span>
    </nav>

    <% if (currentUser && currentUser.banned === 1) { %>
    <div class="bg-red-100 border border-red-300 rounded-xl p-4 shadow-sm mb-4">
        <div class="flex items-start gap-3">
            <span class="text-xl">⚠️</span>
            <div class="text-sm text-red-800">
                <p class="font-bold mb-1">Account Suspended</p>
                <p class="mb-2">Your account has been suspended. You cannot write reviews.</p>
            </div>
        </div>
    </div>
<% } else if (!currentUser) { %>
    <div class="bg-[#def0ff] border border-[#bce0ff] rounded-xl p-4 shadow-sm mb-4">
        <div class="flex items-start gap-3">
            <span class="text-xl">🔒</span>
            <div class="text-sm text-[#004085]">
                <p class="font-bold mb-1">Reviews are always anonymous</p>
                <p class="mb-2">You do not need an account to write a review.</p>
            </div>
        </div>
    </div>
<% } else { %>
    <div class="bg-[#def0ff] border border-[#bce0ff] rounded-xl p-4 shadow-sm mb-4">
        <div class="flex items-start gap-3">
            <span class="text-xl">🔒</span>
            <div class="text-sm text-[#004085]">
                <p class="font-bold mb-1">You are signed in</p>
                <p class="mb-2">Your review will be anonymous.</p>
            </div>
        </div>
    </div>
<% } %>

    <form action="/submit-review" method="POST" id="reviewForm" class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm space-y-6">
        
        <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-5 tracking-tight">Your Review</h2>
            
            <div class="space-y-5">
                <!-- Select School -->
                <div>
                    <label class="block text-sm font-bold text-slate-900 mb-2">Select School <span class="text-rose-500">*</span></label>
                    <div class="relative">
                        <input type="text" id="schoolName" name="schoolName" placeholder="Search for a UK school..." class="w-full px-4 py-3 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition" required autocomplete="off">
                        <div id="autocompleteResults" class="absolute z-20 w-full bg-white border border-slate-200 rounded-lg shadow-lg mt-1 max-h-60 overflow-y-auto hidden"></div>
                    </div>
                </div>

                <!-- Recommend -->
                <div>
                    <label class="block text-sm font-bold text-slate-900 mb-2">Would you recommend this school? <span class="text-rose-500">*</span></label>
                    <input type="hidden" id="recommend" name="recommend" required value="">
                    <div class="flex gap-2">
                        <button type="button" class="recommend-option flex-1 py-3 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50 transition" data-value="yes">Yes</button>
                        <button type="button" class="recommend-option flex-1 py-3 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50 transition" data-value="no">No</button>
                        <button type="button" class="recommend-option flex-1 py-3 bg-white border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50 transition" data-value="unsure">Unsure</button>
                    </div>
                    <div id="recommendError" class="text-rose-500 text-xs mt-1 hidden">Please select whether you would recommend this school</div>
                </div>

                <!-- I am a & Year Group - side by side -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-slate-900 mb-2">I am a <span class="text-rose-500">*</span></label>
                        <select id="userType" name="userType" required class="w-full px-3 py-3 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                            <option value="">Select...</option>
                            <option value="student">Student</option>
                            <option value="parent">Parent</option>
                            <option value="staff">Staff</option>
                            <option value="former_student">Alumni</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-900 mb-2">Child's Year Group <span class="text-rose-500">*</span></label>
                        <select id="yearGroup" name="yearGroup" required class="w-full px-3 py-3 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                            <option value="" disabled selected>Required</option>
                            <option value="primary">Reception / Year 1-6</option>
                            <option value="secondary">Year 7-11 (Secondary)</option>
                            <option value="sixth_form">Sixth Form (Year 12-13)</option>
                        </select>
                    </div>
                </div>

                <!-- Year(s) of attendance -->
                <div>
                    <label class="block text-sm font-bold text-slate-900 mb-2">Year(s) of attendance <span class="text-rose-500">*</span></label>
                    <div class="grid grid-cols-2 gap-4">
                        <select id="yearFrom" name="yearFrom" required class="w-full px-3 py-3 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                            <option value="" disabled selected>From</option>
                            <option value="2019">2019</option><option value="2020">2020</option><option value="2021">2021</option>
                            <option value="2022">2022</option><option value="2023">2023</option><option value="2024">2024</option>
                            <option value="2025">2025</option><option value="2026">2026</option>
                        </select>
                        <select id="yearTo" name="yearTo" required class="w-full px-3 py-3 bg-white border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                            <option value="" disabled selected>To</option>
                            <option value="2019">2019</option><option value="2020">2020</option><option value="2021">2021</option>
                            <option value="2022">2022</option><option value="2023">2023</option><option value="2024">2024</option>
                            <option value="2025">2025</option><option value="2026">2026</option>
                        </select>
                    </div>
                    <div id="yearError" class="text-rose-500 text-xs mt-1 hidden">To year cannot be before From year</div>
                </div>
            </div>
        </div>

        <!-- Rating Breakdown -->
        <div>
