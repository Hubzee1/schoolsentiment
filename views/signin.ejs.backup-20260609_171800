<%- include('partials/header') %>

<div class="container" style="padding: 2rem 0; display: flex; justify-content: center; align-items: center; min-height: 60vh;">
    <div style="background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); width: 100%; max-width: 400px;">
        <h1 style="color: #2A7CDE; text-align: center; margin-bottom: 0.5rem; font-size: 1.8rem;">Sign In</h1>
        <p style="text-align: center; color: #666; margin-bottom: 2rem; font-size: 0.9rem;">No password needed — just your email</p>
        
        <% if (message) { %>
            <div style="background: #fee2e2; color: #991b1b; padding: 0.75rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem; text-align: center;">
                <%= message %>
            </div>
        <% } %>
        
        <% if (emailSent) { %>
            <div style="background: #d1fae5; color: #065f46; padding: 0.75rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem; text-align: center;">
                ✅ Magic link sent! Click the link in your email (or see below for testing).
            </div>
        <% } %>
        
        <form action="/send-magic-link" method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div>
                <label style="display: block; margin-bottom: 0.5rem; color: #333; font-weight: bold; font-size: 0.95rem;">Email Address</label>
                <input type="email" 
                       name="email"
                       style="width: 100%; padding: 0.9rem; border: 2px solid #ddd; border-radius: 8px; font-size: 1rem; box-sizing: border-box;"
                       placeholder="your@email.com"
                       required>
                <% if (claimReviewId) { %>
                    <input type="hidden" name="claimReviewId" value="<%= claimReviewId %>">
                <% } %>
            </div>
            
            <div>
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                    <input type="checkbox" id="termsAgreed" name="termsAgreed" required style="width: 1.1rem; height: 1.1rem;">
                    <span style="font-size: 0.85rem; color: #333;">
                        I agree to the <a href="/terms" target="_blank" style="color: #2A7CDE;">Terms of Service</a> and 
                        <a href="/privacy" target="_blank" style="color: #2A7CDE;">Privacy Policy</a>
                    </span>
                </label>
            </div>
            
            <button type="submit" id="submitBtn" 
                    style="background: #2A7CDE; color: white; border: none; padding: 1rem; border-radius: 8px; cursor: pointer; font-size: 1rem; font-weight: bold; opacity: 0.5; transition: opacity 0.2s;"
                    disabled>
                Send Magic Link ✨
            </button>
        </form>

<script>
    const checkbox = document.getElementById('termsAgreed');
    const submitBtn = document.getElementById('submitBtn');
    
    if (checkbox && submitBtn) {
        checkbox.addEventListener('change', function() {
            if (this.checked) {
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
            } else {
                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.5';
            }
        });
    }
</script>
        
        <div style="text-align: center; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #eee;">
            <p style="color: #666; margin-bottom: 1rem; font-size: 0.9rem;">No account needed to write reviews</p>
            <a href="/review" style="color: #2A7CDE; text-decoration: none; font-weight: bold; font-size: 0.9rem;">
                Continue as Guest to Write a Review
            </a>
        </div>
        
        <div style="text-align: center; margin-top: 1rem;">
            <p style="color: #999; font-size: 0.8rem;">✨ Your reviews stay anonymous — accounts just help you manage them</p>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
