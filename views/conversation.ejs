<%- include('partials/header') %>

<div class="bg-[#fefbf0] text-slate-900 antialiased min-h-screen flex flex-col relative overflow-x-hidden">
  
  <!-- FAINT BACKGROUND FACES -->
  <div class="absolute inset-0 opacity-[0.008] pointer-events-none select-none z-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full min-h-screen" viewBox="0 0 1200 1000" preserveAspectRatio="xMidYMid slice">
      <g stroke="#000" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <g transform="translate(650, 180)"><circle cx="90" cy="90" r="80"/><path d="M60 75 Q75 60 90 75 M100 75 Q115 60 130 75" stroke-width="14"/><path d="M50 105 Q90 150 130 105 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 132 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(250, 680)"><circle cx="110" cy="110" r="98"/><path d="M70 95 Q90 75 110 95 M120 95 Q140 75 160 95" stroke-width="16"/><path d="M55 135 Q110 195 165 135 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(710, 700)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(940, 740)"><circle cx="85" cy="85" r="76"/><path d="M55 75 Q70 60 85 75 M95 75 Q110 60 125 75" stroke-width="12"/><path d="M48 110 Q85 155 122 110 Z" fill="#000" opacity="0.15"/></g>
      </g>
    </svg>
  </div>

  <div class="relative z-10 flex-grow">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-6 sm:py-10">
      
      <!-- Header -->
      <div class="border-b border-slate-200 pb-4 mb-6">
        <h1 class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tight"><%= ad ? ad.title : 'Conversation' %></h1>
        <p class="text-xs text-slate-500 mt-1 font-medium"><%= ad ? ad.schoolName : '' %></p>
      </div>

      <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
        <div class="p-6 space-y-4 max-h-96 overflow-y-auto" id="messagesContainer">
          <% messages.forEach(msg => { %>
            <% const isMine = msg.fromUserId === currentUser.id; %>
            <div class="flex <%= isMine ? 'justify-end' : 'justify-start' %>">
              <div class="max-w-[70%] <%= isMine ? 'bg-indigo-600 text-white' : 'bg-slate-100 text-slate-900' %> rounded-lg p-3">
                <p class="text-sm"><%= msg.message %></p>
                <p class="text-xs <%= isMine ? 'text-indigo-200' : 'text-slate-400' %> mt-1">
                  <%= new Date(msg.createdAt).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
                </p>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="border-t border-slate-200 p-4 bg-slate-50">
          <form id="replyForm" class="flex gap-2">
            <input type="text" id="messageInput" placeholder="Type your reply..." class="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm">
            <button type="submit" class="bg-black hover:bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-semibold transition">Send</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('replyForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = document.getElementById('messageInput').value.trim();
    if (!message) return;
    
    const sendBtn = document.querySelector('#replyForm button[type="submit"]');
    const originalText = sendBtn.textContent;
    sendBtn.textContent = 'Sending...';
    sendBtn.disabled = true;
    
    const response = await fetch('/send-reply/<%= ad.id %>/<%= otherUserId %>', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: message })
    });
    
    if (response.ok) {
        document.getElementById('messageInput').value = '';
        alert('✅ Message sent successfully!');
        setTimeout(() => window.location.reload(), 500);
    } else {
        alert('❌ Error sending message');
    }
    
    sendBtn.textContent = originalText;
    sendBtn.disabled = false;
});
</script>

<%- include('partials/footer') %>
