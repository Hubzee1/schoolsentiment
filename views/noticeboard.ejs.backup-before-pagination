        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 132 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(250, 680)"><circle cx="110" cy="110" r="98"/><path d="M70 95 Q90 75 110 95 M120 95 Q140 75 160 95" stroke-width="16"/><path d="M55 135 Q110 195 165 135 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(710, 700)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(940, 740)"><circle cx="85" cy="85" r="76"/><path d="M55 75 Q70 60 85 75 M95 75 Q110 60 125 75" stroke-width="12"/><path d="M48 110 Q85 155 122 110 Z" fill="#000" opacity="0.15"/></g>
      </g>
    </svg>
  </div>

  <!-- BREADCRUMB -->
  <div class="max-w-6xl mx-auto px-6 pt-6 w-full flex justify-between items-center relative z-10">
    <nav class="text-xs text-slate-500 font-medium tracking-tight">
      <a href="/" class="hover:text-slate-800 transition-colors">Home</a> 
      <span class="mx-2 text-slate-300">&gt;</span> 
      <a href="/school/<%= encodeURIComponent(schoolName) %>" class="hover:text-slate-800 transition-colors"><%= unescapeSchoolName(schoolName) %></a>
      <span class="mx-2 text-slate-300">&gt;</span> 
      <span class="text-slate-800 font-semibold">Noticeboard</span>
    </nav>
    
    <% if (currentUser) { %>
      <a href="/post-ad/<%= encodeURIComponent(schoolName) %>" class="bg-black hover:bg-slate-800 text-white text-xs font-semibold px-4 py-2 rounded-full transition-all shadow-sm tracking-wide">+ Post an Item</a>
    <% } else { %>
      <a href="/signin" class="bg-black hover:bg-slate-800 text-white text-xs font-semibold px-4 py-2 rounded-full transition-all shadow-sm tracking-wide">Sign in to Post</a>
    <% } %>
  </div>

  <!-- HEADER -->
  <header class="max-w-3xl mx-auto text-center px-6 pt-12 pb-8 relative z-10 w-full">
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
      <%= schoolName.replace(" School", "") %> <span class="bg-amber-100 px-3 py-1 rounded-md text-amber-900 font-bold text-3xl sm:text-4xl align-middle inline-block ml-1">Noticeboard</span>
    </h1>
    <p class="mt-4 text-sm sm:text-base text-slate-600 max-w-xl mx-auto leading-relaxed font-medium">
      <% if (ads && ads.length === 0) { %>
        Nothing on the board yet! Be the first to pass something down. Clear out the wardrobe, help a local family, and keep it in the community.
      <% } else { %>
        Pre-loved blazers, post-exam calculators. Keep school essentials moving within your local school family.
      <% } %>
    </p>
  </header>
    </p>
  </header>

  <!-- CATEGORY FILTERS -->
  <div class="max-w-4xl mx-auto px-6 mb-10 relative z-10 w-full">
    <div class="flex flex-wrap justify-center items-center gap-2 mt-5">
      <button class="filter-btn active px-4 py-1.5 bg-indigo-600 text-white rounded-full text-xs font-semibold transition-all" data-filter="all">All</button>
      <button class="filter-btn px-4 py-1.5 bg-indigo-50 border border-indigo-100 text-indigo-700 rounded-full text-xs font-semibold hover:bg-indigo-100 transition-all" data-filter="uniform">👕 Uniforms</button>
      <button class="filter-btn px-4 py-1.5 bg-blue-50 border border-blue-100 text-blue-700 rounded-full text-xs font-semibold hover:bg-blue-100 transition-all" data-filter="books">📚 Books</button>
      <button class="filter-btn px-4 py-1.5 bg-green-100 border border-green-300 text-green-800 rounded-full text-xs font-semibold hover:bg-green-200 transition-all" data-filter="sports">⚽ Sports</button>
      <button class="filter-btn px-4 py-1.5 bg-purple-50 border border-purple-200 text-purple-700 rounded-full text-xs font-semibold hover:bg-purple-100 transition-all active-style" data-filter="musical">🎵 Music</button>
      <button class="filter-btn px-4 py-1.5 bg-slate-100 border border-slate-300 text-slate-800 rounded-full text-xs font-semibold hover:bg-slate-200 transition-all" data-filter="other">📦 Other</button>
      <button class="filter-btn px-4 py-1.5 bg-emerald-100 border border-emerald-300 text-emerald-800 rounded-full text-xs font-semibold hover:bg-emerald-200 transition-all" data-filter="free">🎁 Free</button>
      <button class="filter-btn px-4 py-1.5 bg-amber-200 border border-amber-400 text-amber-900 rounded-full text-xs font-semibold hover:bg-amber-300 transition-all" data-filter="wanted">📢 Wanted</button>
    </div>
  </div>

  <!-- NOTICEBOARD ITEMS MATRIX -->
  <main class="max-w-6xl mx-auto px-6 pb-24 relative z-10 w-full flex-grow">
    <div class="flex justify-between items-center mb-6 border-b border-slate-200 pb-3">
      <h2 class="text-lg font-bold text-slate-800 tracking-tight">Latest Items at <%= unescapeSchoolName(schoolName) %></h2>
      <select id="sortSelect" class="bg-transparent text-xs font-semibold text-slate-500 focus:outline-none cursor-pointer hover:text-slate-800">
        <option value="newest">Sort by: Newest First</option>
        <option value="price-low">Price: Low to High</option>
        <option value="price-high">Price: High to Low</option>
      </select>
    </div>

    <div id="items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="col-span-full text-center text-slate-500 py-8">Loading items...</div>
    </div>
  </main>

</div>

<script>
let allAds = [];
let currentSchoolName = '<%= unescapeSchoolName(schoolName) %>';
let currentUser = <%- JSON.stringify(currentUser || null) %>;

// Fetch ads data
fetch('/api/ads')
    .then(r => r.json())
    .then(ads => {
        allAds = ads.filter(ad => ad.status === 'active' && ad.schoolName === currentSchoolName);
        renderItems(allAds);
    });

function renderItems(ads) {
    const container = document.getElementById('items-grid');
    if (!ads || ads.length === 0) {
        container.innerHTML = '<div class="col-span-full text-center text-slate-500 py-8">No items posted yet. Be the first!</div>';
        return;
    }
    
    container.innerHTML = ads.map(ad => {
        const categoryColors = {
            uniform: { bg: 'bg-indigo-50', text: 'text-indigo-700', label: 'Uniform' },
            books: { bg: 'bg-blue-50', text: 'text-blue-700', label: 'Books' },
            sports: { bg: 'bg-green-100', text: 'text-green-800', label: 'Sports' },
            other: { bg: 'bg-slate-50', text: 'text-slate-700', label: 'Other' },
            musical: { bg: 'bg-purple-100', text: 'text-purple-800', label: 'Music' },
            wanted: { bg: 'bg-amber-50', text: 'text-amber-700', label: 'Wanted' }
        };
        const color = categoryColors[ad.category] || categoryColors.other;
        const priceDisplay = ad.isWanted ? 'WANTED' : (ad.isFree ? 'FREE' : '£' + ad.price);
        const priceColor = ad.isWanted ? 'text-amber-600' : (ad.isFree ? 'text-emerald-600' : 'text-slate-900');
        
        const imageHtml = ad.imageUrl ? 
            '<div class="w-full h-40 bg-slate-50 rounded-xl border border-slate-100 mb-4 overflow-hidden">' +
                '<img src="' + ad.imageUrl + '" alt="' + escapeHtml(ad.title) + '" class="w-full h-full object-cover">' +
            '</div>' : 
            '<div class="w-full h-40 bg-slate-50 rounded-xl border border-slate-100 mb-4 flex items-center justify-center text-slate-300">' +
                '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">' +
                    '<path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />' +
                '</svg>' +
            '</div>';
        
        return '<a href="/ad/' + ad.id + '" class="block bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-all cursor-pointer">' +
                '<div>' +
                    imageHtml +
                    '<div class="flex justify-between items-start">' +
                        '<span class="px-2.5 py-0.5 ' + color.bg + ' ' + color.text + ' rounded-full text-[10px] font-bold tracking-wide uppercase">' + color.label + '</span>' +
                        '<span class="text-sm font-extrabold ' + priceColor + '">' + priceDisplay + '</span>' +
                    '</div>' +
                    '<h3 class="font-bold text-slate-900 mt-3 text-base tracking-tight">' + escapeHtml(ad.title) + '</h3>' +
                    '<p class="text-xs text-slate-500 mt-1 line-clamp-2">' + escapeHtml(ad.description) + '</p>' +
                    '<p class="text-xs text-slate-400 mt-2">Condition: ' + ad.condition + '</p>' +
                '</div>' +
                '<div class="mt-5 pt-3 border-t border-slate-100 flex justify-between items-center">' +
                    '<span class="text-[11px] text-slate-400 font-medium">' + formatDate(ad.createdAt) + '</span>' +
                    '<span class="text-xs font-bold text-indigo-600">View Details →</span>' +
                '</div>' +
            '</a>';
    }).join('');
}

function formatDate(dateString) {
    const date = new Date(dateString);
    const now = new Date();
    const diffHours = Math.floor((now - date) / (1000 * 60 * 60));
    if (diffHours < 1) return 'Posted just now';
    if (diffHours < 24) return 'Posted ' + diffHours + ' hrs ago';
    if (diffHours < 48) return 'Posted Yesterday';
    return 'Posted ' + Math.floor(diffHours / 24) + ' days ago';
}

function capitalizeConditionDisplay(condition) {
        if (!condition) return '';
        return condition.split('-').map(part => part.charAt(0).toUpperCase() + part.slice(1).toLowerCase()).join('-');
    }

    function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}function formatDate(dateString) {
    const date = new Date(dateString);
    const now = new Date();
    const diffHours = Math.floor((now - date) / (1000 * 60 * 60));
    if (diffHours < 1) return 'Posted just now';
    if (diffHours < 24) return `Posted ${diffHours} hrs ago`;
    if (diffHours < 48) return 'Posted Yesterday';
    return `Posted ${Math.floor(diffHours / 24)} days ago`;
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// Category filtering
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const filter = this.getAttribute('data-filter');
        
        let filtered = [...allAds];
        if (filter === 'all') {
            filtered = allAds;
        } else if (filter === 'free') {
            filtered = allAds.filter(ad => ad.isFree === true);
        } else if (filter === 'wanted') {
            filtered = allAds.filter(ad => ad.isWanted === true);
        } else {
            filtered = allAds.filter(ad => ad.category === filter);
        }
        
        renderItems(filtered);
        
        // Remove active class from all buttons
        document.querySelectorAll('.filter-btn').forEach(b => {
            b.classList.remove('bg-indigo-600', 'text-white', 'active');
            b.classList.add('bg-indigo-50', 'border', 'border-indigo-100', 'text-indigo-700');
            // Also remove any inline styles
            b.style.backgroundColor = '';
            b.style.color = '';
        });
        // Add active class to clicked button
        this.classList.remove('bg-indigo-50', 'border', 'border-indigo-100', 'text-indigo-700');
        this.classList.add('bg-indigo-600', 'text-white', 'active');
        // Force the style
        this.style.backgroundColor = '#4f46e5';
        this.style.color = 'white';
    });
});

// Sorting
document.getElementById('sortSelect').addEventListener('change', function() {
    const sortBy = this.value;
    let sorted = [...allAds];
    if (sortBy === 'price-low') {
        sorted.sort((a, b) => parseFloat(a.price) - parseFloat(b.price));
    } else if (sortBy === 'price-high') {
        sorted.sort((a, b) => parseFloat(b.price) - parseFloat(a.price));
    } else {
        sorted.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
    }
    renderItems(sorted);
});

// Message modal
const modalHtml = `
<div id="messageModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 max-w-md w-full mx-4">
        <h3 class="text-lg font-bold mb-2">Contact Seller</h3>
        <p class="text-sm text-slate-500 mb-4" id="modalItem"></p>
        <textarea id="messageText" rows="4" class="w-full px-3 py-2 border border-slate-300 rounded-lg mb-4" placeholder="Your message..."></textarea>
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mb-4">
            <p class="text-xs text-amber-700">⚠️ Safety tip: Arrange collection in a public place. School Sentiment does not handle payments.</p>
        </div>
        <div class="flex gap-3">
            <button id="sendMessageBtn" class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700">Send Message</button>
            <button id="closeModalBtn" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-300">Cancel</button>
        </div>
    </div>
</div>`;

if (!document.getElementById('messageModal')) {
    document.body.insertAdjacentHTML('beforeend', modalHtml);
}

const modal = document.getElementById('messageModal');
let currentAdId = null;

document.getElementById('closeModalBtn')?.addEventListener('click', () => {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
});

document.getElementById('sendMessageBtn')?.addEventListener('click', async () => {
    const message = document.getElementById('messageText').value;
    if (!message.trim()) {
        alert('Please enter a message');
        return;
    }
    
    const response = await fetch(`/message-about-ad/${currentAdId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: message })
    });
    
    if (response.ok) {
        alert('✅ Message sent! The seller will contact you.');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.getElementById('messageText').value = '';
        setTimeout(() => window.location.reload(), 500);
    } else if (response.status === 401) {
        alert('Please sign in to send messages');
    } else {
        alert('❌ Error sending message');
    }
});
</script>

<%- include('partials/footer') %>
