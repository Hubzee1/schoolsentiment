<%- include('partials/header') %>

<div class="bg-[#fefbf0] text-slate-900 antialiased min-h-screen flex flex-col relative overflow-x-hidden">
  
  <!-- FAINT BACKGROUND FACES -->
  <div class="absolute inset-0 opacity-[0.008] pointer-events-none select-none z-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full min-h-screen" viewBox="0 0 1200 1000" preserveAspectRatio="xMidYMid slice">
      <g stroke="#000" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <g transform="translate(650, 180)"><circle cx="90" cy="90" r="80"/><path d="M60 75 Q75 60 90 75 M100 75 Q115 60 130 75" stroke-width="14"/><path d="M50 105 Q90 150 130 105 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 132 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(250, 680)"><circle cx="110" cy="110" r="98"/><path d="M70 95 Q90 75 110 95 M120 95 Q140 75 160 95" stroke-width="16"/><path d="M55 135 Q110 195 165 135 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(710, 700)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(940, 740)"><circle cx="85" cy="85" r="76"/><path d="M55 75 Q70 60 85 75 M95 75 Q110 60 125 75" stroke-width="12"/><path d="M48 110 Q85 155 122 110 Z" fill="#000" opacity="0.15"/></g>
      </g>
    </svg>
  </div>

  <div class="relative z-10 flex-grow">
    
    <!-- SCHOOL SEARCH BAR -->
    <div class="max-w-6xl mx-auto px-4 pt-6 w-full">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 text-center">School <span class="bg-amber-100 px-4 py-1.5 rounded-md text-amber-900 font-bold text-4xl sm:text-5xl align-middle inline-block ml-2">Noticeboard</span></h1>
<p class="text-sm text-slate-500 mt-2 text-center max-w-2xl mx-auto">Pre-loved blazers, post-exam calculators. Keep school essentials<br>moving within your local school family.</p>
      
      <div class="w-full max-w-[600px] mx-auto mt-4 px-4">
        <div class="relative">
          <input type="text" id="schoolSearch" placeholder="Search for a school noticeboard..." class="w-full px-4 py-3 pr-14 border border-slate-300 rounded-full shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm">
          <button type="button" id="searchButton" class="absolute right-2 top-1/2 transform -translate-y-1/2 bg-black hover:bg-slate-800 rounded-full w-9 h-9 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
          <div id="schoolSearchResults" class="absolute z-20 w-full bg-white border border-slate-200 rounded-xl shadow-lg mt-2 max-h-64 overflow-y-auto hidden"></div>
        </div>
      </div>
    </div>

    <!-- CATEGORY FILTERS - 8 FILTERS ON 2 LINES -->
    <div class="max-w-6xl mx-auto px-4 mb-8 relative z-10 w-full">
      <div class="flex flex-wrap justify-center items-center gap-1.5 mt-3">
        <a href="?page=1&filter=all&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= (currentFilter === 'all' || !currentFilter) ? 'bg-indigo-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-indigo-50 border border-indigo-100 text-indigo-700 hover:bg-indigo-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">All</a>
        <a href="?page=1&filter=uniform&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'uniform' ? 'bg-indigo-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-indigo-50 border border-indigo-100 text-indigo-700 hover:bg-indigo-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Uniforms</a>
        <a href="?page=1&filter=books&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'books' ? 'bg-blue-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-blue-50 border border-blue-100 text-blue-700 hover:bg-blue-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Books</a>
        <a href="?page=1&filter=sports&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'sports' ? 'bg-green-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-green-100 border border-green-300 text-green-800 hover:bg-green-200' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Sports</a>
        <a href="?page=1&filter=other&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'other' ? 'bg-purple-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-purple-50 border border-purple-100 text-purple-700 hover:bg-purple-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Other</a>
        <a href="?page=1&filter=free&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'free' ? 'bg-emerald-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-emerald-50 border border-emerald-200 text-emerald-700 hover:bg-emerald-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Free</a>
        <a href="?page=1&filter=wanted&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'wanted' ? 'bg-amber-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-amber-50 border border-amber-200 text-amber-700 hover:bg-amber-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Wanted</a>
        <a href="?page=1&filter=schools&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'schools' ? 'bg-slate-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-slate-100 border border-slate-200 text-slate-700 hover:bg-slate-200' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Schools Only</a>
      </div>
    </div>

    <!-- NOTICEBOARD ITEMS MATRIX -->
    <main class="max-w-6xl mx-auto px-6 pb-24 relative z-10 w-full flex-grow">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 border-b border-slate-200 pb-3 gap-2">
        <div class="flex items-center gap-20">
          <h2 class="text-lg font-bold text-slate-800 tracking-tight">
            <span class="hidden sm:inline">Latest Items</span>
            <span class="sm:hidden">Latest Items</span>
          </h2>
          <% if (currentUser) { %>
            <a href="/post-ad/" class="bg-amber-400 hover:bg-amber-500 text-slate-950 text-xs font-bold px-3 py-1.5 rounded-full transition-all">+ Post Ad</a>
          <% } else { %>
            <a href="/signin" class="bg-black hover:bg-slate-800 text-white text-xs font-bold px-3 py-1.5 rounded-full transition-all">Sign in to Post</a>
          <% } %>
        </div>
        <div class="flex items-center gap-2">
          
          <div class="w-full sm:w-auto mt-1"><select id="sortSelect" class="bg-transparent text-xs font-semibold text-slate-500 focus:outline-none cursor-pointer hover:text-slate-800">
            <option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Sort by: Newest First</option>
            <option value="price-low" <%= currentSort === 'price-low' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="price-high" <%= currentSort === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
          </select></div>
        </div>
      </div>

      <% if (ads.length === 0) { %>
        <div class="text-center py-12">
          <p class="text-slate-500 text-sm">No items found in this category.</p>
          <a href="?filter=all" class="text-indigo-600 hover:underline text-sm mt-2 inline-block">View all items</a>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="items-grid">
          <% ads.forEach(ad => { %>
            <div class="bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-md transition-shadow">
              <a href="/ad/<%= ad.id %>" class="block">
                <div class="aspect-square bg-slate-100 overflow-hidden">
                  <% if (ad.imageUrl) { %>
                    <img src="<%= ad.imageUrl %>" alt="<%= ad.title %>" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center text-slate-300 text-4xl">📷</div>
                  <% } %>
                </div>
              </a>
              <div class="p-3">
                <div class="flex justify-between items-start gap-1">
                  <a href="/ad/<%= ad.id %>" class="font-bold text-slate-900 text-sm hover:text-indigo-600 truncate"><%= ad.title %></a>
                  <span class="text-sm font-black text-slate-900 shrink-0"><%= ad.isFree ? 'FREE' : '£' + ad.price %></span>
                </div>
                <p class="text-[10px] text-slate-500 truncate"><%= ad.schoolName %></p>
                <div class="flex flex-wrap gap-1 mt-2">
                  <span class="text-[9px] font-medium bg-slate-100 text-slate-600 px-2 py-0.5 rounded-full"><%= ad.category %></span>
                  <% if (ad.isWanted) { %>
                    <span class="text-[9px] font-medium bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Wanted</span>
                  <% } %>
                  <% if (ad.isFree) { %>
                    <span class="text-[9px] font-medium bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full">Free</span>
                  <% } %>
                </div>
                <div class="flex justify-between items-center mt-2">
                  <span class="text-[9px] text-slate-400"><%= new Date(ad.createdAt).toLocaleDateString('en-GB') %></span>
                  <button class="save-ad-btn text-gray-400 hover:text-red-500 text-sm" data-ad-id="<%= ad.id %>" data-saved="false">🤍</button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Pagination -->
      <% if (pagination.totalPages > 1) { %>
        <div class="flex justify-center items-center gap-2 mt-8">
          <a href="?page=<%= pagination.currentPage - 1 %>&filter=<%= currentFilter || 'all' %>&sort=<%= currentSort || 'newest' %>" class="px-3 py-1 rounded-full text-xs font-semibold border border-slate-200 hover:bg-slate-50 <%= pagination.currentPage === 1 ? 'opacity-50 pointer-events-none' : '' %>">Previous</a>
          <span class="text-xs text-slate-500"><%= pagination.currentPage %> of <%= pagination.totalPages %></span>
          <a href="?page=<%= pagination.currentPage + 1 %>&filter=<%= currentFilter || 'all' %>&sort=<%= currentSort || 'newest' %>" class="px-3 py-1 rounded-full text-xs font-semibold border border-slate-200 hover:bg-slate-50 <%= pagination.currentPage === pagination.totalPages ? 'opacity-50 pointer-events-none' : '' %>">Next</a>
        </div>
      <% } %>
    </main>
  </div>
</div>

<script>
// School search autocomplete
const searchInput = document.getElementById('schoolSearch');
const resultsDiv = document.getElementById('schoolSearchResults');
let schools = [];

fetch('/api/schools')
    .then(res => res.json())
    .then(data => { schools = data; });

if (searchInput) {
    searchInput.addEventListener('input', function() {
        const query = this.value.trim().toLowerCase();
        if (query.length < 2) {
            resultsDiv.classList.add('hidden');
            return;
        }
        const matches = schools.filter(s => s.name.toLowerCase().includes(query) || s.town.toLowerCase().includes(query)).slice(0, 8);
        if (matches.length === 0) {
            resultsDiv.classList.add('hidden');
            return;
        }
        let html = '';
        matches.forEach(school => {
            html += `<div class="p-3 hover:bg-slate-50 cursor-pointer border-b border-slate-100 last:border-0" data-school="${encodeURIComponent(school.name)}">
                        <div class="font-semibold text-slate-800 text-sm">${school.name}</div>
                        <div class="text-xs text-slate-500">${school.town} • ${school.postcode}</div>
                    </div>`;
        });
        resultsDiv.innerHTML = html;
        resultsDiv.classList.remove('hidden');
        
        document.querySelectorAll('[data-school]').forEach(el => {
            el.addEventListener('click', function() {
                window.location.href = '/school/' + this.dataset.school + '/noticeboard';
            });
        });
    });
    
    document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !resultsDiv.contains(e.target)) {
            resultsDiv.classList.add('hidden');
        }
    });
}

// Search button handler
const searchButton = document.getElementById('searchButton');
if (searchButton) {
    searchButton.addEventListener('click', function(e) {
        e.preventDefault();
        const query = document.getElementById('schoolSearch').value.trim();
        if (query) {
            const matchedSchool = schools.find(s => s.name.toLowerCase() === query.toLowerCase());
            if (matchedSchool) {
                window.location.href = '/school/' + encodeURIComponent(matchedSchool.name) + '/noticeboard';
            } else {
                const partialMatch = schools.find(s => s.name.toLowerCase().includes(query.toLowerCase()));
                if (partialMatch) {
                    window.location.href = '/school/' + encodeURIComponent(partialMatch.name) + '/noticeboard';
                } else {
                    window.location.href = '/search-noticeboard?school=' + encodeURIComponent(query);
                }
            }
        }
    });
}

// Sort dropdown
const sortSelect = document.getElementById('sortSelect');
if (sortSelect) {
    sortSelect.addEventListener('change', function() {
        const url = new URL(window.location.href);
        url.searchParams.set('sort', this.value);
        url.searchParams.set('page', '1');
        window.location.href = url.toString();
    });
}

// ========== SYNC SAVED ADS HEARTS ==========
document.addEventListener('DOMContentLoaded', function() {
    // Fetch saved ads and update heart icons
    fetch('/api/saved-ads')
        .then(res => res.json())
        .then(savedIds => {
            if (!savedIds || savedIds.length === 0) return;
            document.querySelectorAll('.save-ad-btn').forEach(btn => {
                const adId = btn.getAttribute('data-ad-id');
                if (savedIds.includes(adId)) {
                    btn.setAttribute('data-saved', 'true');
                    btn.innerHTML = '❤️';
                    btn.style.color = 'red';
                }
            });
        })
        .catch(err => console.error('Error fetching saved ads:', err));

    // Save/unsave functionality
    document.querySelectorAll('.save-ad-btn').forEach(btn => {
        btn.addEventListener('click', async function(e) {
            e.preventDefault();
            e.stopPropagation();
            const adId = this.getAttribute('data-ad-id');
            const isSaved = this.getAttribute('data-saved') === 'true';
            const url = isSaved ? '/unsave-ad/' + adId : '/save-ad/' + adId;

            try {
                const response = await fetch(url, { method: 'POST' });
                if (response.ok) {
                    if (isSaved) {
                        this.setAttribute('data-saved', 'false');
                        this.innerHTML = '🤍';
                        this.style.color = 'gray';
                    } else {
                        this.setAttribute('data-saved', 'true');
                        this.innerHTML = '❤️';
                        this.style.color = 'red';
                    }
                } else if (response.status === 401) {
                    alert('Please sign in to save ads');
                }
            } catch(err) {
                console.error('Error saving ad:', err);
            }
        });
    });
});
</script>

<%- include('partials/footer') %>
