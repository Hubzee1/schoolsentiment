<%- include('partials/header') %>

<div class="bg-[#fefbf0] text-slate-900 antialiased min-h-screen flex flex-col relative overflow-x-hidden">
  
  <div class="absolute inset-0 opacity-[0.008] pointer-events-none select-none z-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full min-h-screen" viewBox="0 0 1200 1000" preserveAspectRatio="xMidYMid slice">
      <g stroke="#000" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <g transform="translate(650, 180)"><circle cx="90" cy="90" r="80"/><path d="M60 75 Q75 60 90 75 M100 75 Q115 60 130 75" stroke-width="14"/><path d="M50 105 Q90 150 130 105 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 132 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(250, 680)"><circle cx="110" cy="110" r="98"/><path d="M70 95 Q90 75 110 95 M120 95 Q140 75 160 95" stroke-width="16"/><path d="M55 135 Q110 195 165 135 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(710, 700)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(940, 740)"><circle cx="85" cy="85" r="76"/><path d="M55 75 Q70 60 85 75 M95 75 Q110 60 125 75" stroke-width="12"/><path d="M48 110 Q85 155 122 110 Z" fill="#000" opacity="0.15"/></g>
      </g>
    </svg>
  </div>

  <div class="relative z-10 flex-grow">
    <div class="max-w-md mx-auto px-4 sm:px-6 py-6 sm:py-10">
      
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-6 sm:p-8">
          
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
            </div>
            <h1 class="text-2xl font-black text-slate-900 tracking-tight">Sign In</h1>
            <p class="text-xs text-slate-500 mt-1">No password needed — just your email</p>
          </div>
          
          <% if (message) { %>
            <div class="bg-red-50 border border-red-200 rounded-xl p-3 mb-6">
              <p class="text-red-700 text-sm"><%= message %></p>
            </div>
          <% } %>
          
          <% if (emailSent) { %>
            <div class="bg-green-50 border border-green-200 rounded-xl p-3 mb-6">
              <p class="text-green-700 text-sm">✅ Magic link sent! Click the link in your email to sign in.</p>
            </div>
          <% } %>
          
          <form action="/send-magic-link" method="POST">
            <div class="mb-5">
              <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
              <input type="email" 
                     name="email"
                     class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                     placeholder="your@email.com"
                     required>
              <% if (claimReviewId) { %>
                <input type="hidden" name="claimReviewId" value="<%= claimReviewId %>">
              <% } %>
            </div>
            
            <div class="mb-6">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" id="termsAgreed" name="termsAgreed" required class="w-4 h-4 text-indigo-600 rounded border-slate-300 focus:ring-indigo-500">
                <span class="text-sm text-slate-600">
                  I agree to the <a href="/terms" target="_blank" class="text-indigo-600 hover:underline">Terms of Service</a> and 
                  <a href="/privacy" target="_blank" class="text-indigo-600 hover:underline">Privacy Policy</a>
                </span>
              </label>
            </div>
            
            <button type="submit" id="submitBtn" 
                    class="w-full bg-black hover:bg-slate-800 text-white font-semibold py-3 px-4 rounded-full transition disabled:opacity-50 disabled:cursor-not-allowed"
                    disabled>
              Send Magic Link ✨
            </button>
            
            <div class="mt-5 p-3 bg-blue-50 rounded-xl border-l-4 border-indigo-500">
              <p class="text-xs text-indigo-700">
                📧 <strong>Didn't receive the email?</strong> Check your spam folder. 
                <a href="#" onclick="document.querySelector('form').dispatchEvent(new Event('submit')); return false;" class="text-indigo-700 underline">Click here to resend</a>
              </p>
            </div>
          </form>
          
          <div class="text-center mt-6 pt-6 border-t border-slate-200">
            <p class="text-xs text-slate-500 mb-3">No account needed to write reviews</p>
            <a href="/review" class="text-indigo-600 hover:text-indigo-700 font-semibold text-sm">
              Continue as Guest to Write a Review →
            </a>
          </div>
          
          <div class="text-center mt-4">
            <p class="text-xs text-slate-400">✨ Your reviews stay anonymous — accounts just help you manage them</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const checkbox = document.getElementById('termsAgreed');
  const submitBtn = document.getElementById('submitBtn');
  
  if (checkbox && submitBtn) {
    checkbox.addEventListener('change', function() {
      if (this.checked) {
        submitBtn.disabled = false;
      } else {
        submitBtn.disabled = true;
      }
    });
  }
</script>

<%- include('partials/footer') %>
