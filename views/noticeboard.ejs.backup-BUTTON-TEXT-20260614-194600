<%- include('partials/header') %>

<%
  // Helper function to unescape school name
  function unescapeSchoolName(encodedName) {
    if (!encodedName) return '';
    return encodedName.replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'");
  }
%>

<div class="bg-[#fefbf0] text-slate-900 antialiased min-h-screen relative overflow-x-hidden flex flex-col justify-between">

  <!-- FAINT BACKGROUND WALLPAPER -->
  <div class="absolute inset-0 opacity-[0.008] pointer-events-none select-none z-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full min-h-screen" viewBox="0 0 1200 1000" preserveAspectRatio="xMidYMid slice">
      <g stroke="#000" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <g transform="translate(650, 180)"><circle cx="90" cy="90" r="80"/><path d="M60 75 Q75 60 90 75 M100 75 Q115 60 130 75" stroke-width="14"/><path d="M50 105 Q90 150 130 105 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 132 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
      </g>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-6 pt-6 w-full flex justify-between items-center relative z-10">
    <div class="flex gap-3">
      <% if (currentUser) { %>
        <a href="/post-ad/<%= encodeURIComponent(schoolName) %>" class="bg-black hover:bg-slate-800 text-white text-xs font-semibold px-4 py-2 rounded-full transition-all shadow-sm tracking-wide">+ Post an Item</a>
      <% } else { %>
        <a href="/signin" class="bg-black hover:bg-slate-800 text-white text-xs font-semibold px-4 py-2 rounded-full transition-all shadow-sm tracking-wide">Sign in to Post</a>
      <% } %>
    </div>
  </div>

  <header class="max-w-3xl mx-auto text-center px-6 pt-12 pb-8 relative z-10 w-full">
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
      <%= schoolName.replace(" School", "") %> <span class="bg-amber-100 px-3 py-1 rounded-md text-amber-900 font-bold text-3xl sm:text-4xl align-middle inline-block ml-1">Noticeboard</span>
    </h1>
    <p class="mt-4 text-sm sm:text-base text-slate-600 max-w-xl mx-auto leading-relaxed font-medium">
      <% if (ads && ads.length === 0) { %>
        Nothing on the board yet! Be the first to pass something down. Clear out the wardrobe, help a local family, and keep it in the community.
      <% } else { %>
        Pre-loved blazers, post-exam calculators. Keep school essentials moving within your local school family.
      <% } %>
    </p>
  </header>

  <!-- CATEGORY FILTERS - 8 FILTERS ON 2 LINES (4 on line 1, 4 on line 2) -->
  <div class="max-w-6xl mx-auto px-4 mb-8 relative z-10 w-full">
    <div class="flex flex-wrap justify-center items-center gap-1.5 mt-3">
      <!-- Line 1: All, Uniforms, Books, Sports -->
      <a href="?page=1&filter=all&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= (currentFilter === 'all' || !currentFilter) ? 'bg-indigo-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-indigo-50 border border-indigo-100 text-indigo-700 hover:bg-indigo-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">All</a>
      <a href="?page=1&filter=uniform&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'uniform' ? 'bg-indigo-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-indigo-50 border border-indigo-100 text-indigo-700 hover:bg-indigo-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Uniforms</a>
      <a href="?page=1&filter=books&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'books' ? 'bg-blue-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-blue-50 border border-blue-100 text-blue-700 hover:bg-blue-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Books</a>
      <a href="?page=1&filter=sports&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'sports' ? 'bg-green-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-green-100 border border-green-300 text-green-800 hover:bg-green-200' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Sports</a>
      
      <!-- Line 2: Other, Free, Wanted, Schools Only -->
      <a href="?page=1&filter=other&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'other' ? 'bg-purple-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-purple-50 border border-purple-100 text-purple-700 hover:bg-purple-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Other</a>
      <a href="?page=1&filter=free&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'free' ? 'bg-emerald-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-emerald-50 border border-emerald-200 text-emerald-700 hover:bg-emerald-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Free</a>
      <a href="?page=1&filter=wanted&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'wanted' ? 'bg-amber-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-amber-50 border border-amber-200 text-amber-700 hover:bg-amber-100' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Wanted</a>
      <a href="?page=1&filter=schools&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'schools' ? 'bg-slate-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-slate-100 border border-slate-200 text-slate-700 hover:bg-slate-200' %> px-3 py-1 rounded-full text-xs font-semibold transition-all">Schools Only</a>
    </div>
  </div>

  <!-- NOTICEBOARD ITEMS MATRIX -->
  <main class="max-w-6xl mx-auto px-6 pb-24 relative z-10 w-full flex-grow">
    <div class="flex justify-between items-center mb-6 border-b border-slate-200 pb-3">
      <!-- Desktop: Shows full text, Mobile: Shows shorter text -->
      <h2 class="text-lg font-bold text-slate-800 tracking-tight">
        <span class="hidden sm:inline">Latest Items at <%= unescapeSchoolName(schoolName) %></span>
        <span class="sm:hidden">Latest Items</span>
      </h2>
      <select id="sortSelect" class="bg-transparent text-xs font-semibold text-slate-500 focus:outline-none cursor-pointer hover:text-slate-800">
        <option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Sort by: Newest First</option>
        <option value="price-low" <%= currentSort === 'price-low' ? 'selected' : '' %>>Price: Low to High</option>
        <option value="price-high" <%= currentSort === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
      </select>
    </div>

    <div id="items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if (ads && ads.length === 0) { %>
        <div class="col-span-full text-center text-slate-500 py-8">No items match your filter. Try a different category!</div>
      <% } else { %>
        <% ads.forEach(ad => { %>
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-all">
            <% if (ad.imageUrl) { %>
              <div class="w-full h-40 bg-slate-50 rounded-xl border border-slate-100 mb-4 overflow-hidden">
                <img src="<%= ad.imageUrl %>" alt="<%= ad.title %>" class="w-full h-full object-cover">
              </div>
            <% } else { %>
              <div class="w-full h-40 bg-slate-50 rounded-xl border border-slate-100 mb-4 flex items-center justify-center text-slate-300">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                </svg>
              </div>
            <% } %>
            <div>
              <div class="flex justify-between items-start gap-2">
                <h3 class="font-bold text-slate-900 text-base leading-tight"><%= ad.title %></h3>
                <span class="text-base font-black text-slate-900 shrink-0"><%= ad.isFree ? 'FREE' : '£' + ad.price %></span>
              </div>
              <div class="flex items-center gap-1 mt-1">
                <span class="text-xs text-slate-500"><%= ad.schoolName %></span>
                <% if (ad.isSchoolVerified) { %>
                  <svg class="w-3.5 h-3.5 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>
                <% } %>
              </div>
              <p class="text-slate-600 text-sm mt-2 line-clamp-2"><%= ad.description %></p>
            </div>
            <div class="mt-4 flex justify-between items-center">
              <span class="text-[10px] font-mono text-slate-400 bg-slate-50 px-2 py-0.5 rounded-full">Ref: <%= ad.publicId %></span>
              <a href="/ad/<%= ad.id %>" class="text-xs font-bold text-slate-800 hover:underline">View Details &rarr;</a>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- PAGINATION -->
    <% if (pagination.totalPages > 1) { %>
      <div class="flex justify-center items-center gap-2 mt-10">
        <% if (pagination.currentPage > 1) { %>
          <a href="?page=<%= pagination.currentPage - 1 %>&filter=<%= currentFilter || 'all' %>&sort=<%= currentSort || 'newest' %>" class="px-3 py-1.5 bg-white border border-slate-200 rounded-full text-xs font-medium hover:bg-slate-50">← Previous</a>
        <% } %>
        <span class="px-3 py-1.5 text-xs text-slate-600">Page <%= pagination.currentPage %> of <%= pagination.totalPages %></span>
        <% if (pagination.currentPage < pagination.totalPages) { %>
          <a href="?page=<%= pagination.currentPage + 1 %>&filter=<%= currentFilter || 'all' %>&sort=<%= currentSort || 'newest' %>" class="px-3 py-1.5 bg-white border border-slate-200 rounded-full text-xs font-medium hover:bg-slate-50">Next →</a>
        <% } %>
      </div>
    <% } %>
  </main>
</div>

<script>
// Sort dropdown handler
const sortSelect = document.getElementById('sortSelect');
if (sortSelect) {
    sortSelect.addEventListener('change', function() {
        const currentUrl = new URL(window.location.href);
        currentUrl.searchParams.set('sort', this.value);
        currentUrl.searchParams.set('page', '1');
        window.location.href = currentUrl.toString();
    });
}
</script>

<%- include('partials/footer') %>
