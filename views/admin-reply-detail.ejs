<%- include('partials/header') %>

<main class="max-w-4xl mx-auto px-4 py-8 flex-grow">
    <div class="mb-6">
        <a href="/admin/flags?type=reply" class="text-indigo-600 hover:text-indigo-800 text-sm font-medium">&larr; Back to Flagged Replies</a>
    </div>

    <h1 class="text-2xl font-bold text-slate-900 mb-6">Reply Details</h1>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-6">
        <div class="flex justify-between items-start mb-4">
            <div>
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Flagged Reply</span>
                <p class="text-sm text-slate-500 mt-1">Flagged on: <%= flag ? new Date(flag.flaggedAt).toLocaleString() : 'Unknown' %></p>
            </div>
            <span class="bg-red-100 text-red-700 text-xs font-bold px-3 py-1 rounded-full">Pending Review</span>
        </div>

        <div class="border-t border-slate-100 pt-4">
            <div class="mb-4">
                <h3 class="text-sm font-semibold text-slate-700">School</h3>
                <p class="text-sm text-slate-600"><%= reply ? reply.schoolName : 'Unknown' %></p>
            </div>

            <div class="mb-4">
                <h3 class="text-sm font-semibold text-slate-700">Reply Content</h3>
                <div class="bg-slate-50 p-4 rounded-lg mt-1 border border-slate-200">
                    <p class="text-sm text-slate-800"><%= reply ? reply.responseText : 'No content' %></p>
                </div>
            </div>

            <div class="mb-4">
                <h3 class="text-sm font-semibold text-slate-700">Flag Reason</h3>
                <p class="text-sm text-slate-600"><%= flag ? flag.reason : 'Unknown' %></p>
            </div>

            <% if (flag && flag.details) { %>
            <div class="mb-4">
                <h3 class="text-sm font-semibold text-slate-700">Additional Details</h3>
                <p class="text-sm text-slate-600"><%= flag.details %></p>
            </div>
            <% } %>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Actions</h2>
        <div class="flex flex-wrap gap-3">
            <button onclick="hideReply()" class="bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-6 rounded-lg text-sm transition">
                Hide Reply
            </button>
            <button onclick="deleteReply()" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-6 rounded-lg text-sm transition">
                Delete Reply
            </button>
            <button onclick="resolveFlag()" class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-6 rounded-lg text-sm transition">
                Resolve Flag
            </button>
        </div>
    </div>
</main>

<script>
const replyId = '<%= reply ? reply.id : "" %>';
const flagId = '<%= flag ? flag.id : "" %>';

async function hideReply() {
    if (!confirm('Are you sure you want to hide this reply?')) return;
    try {
        const response = await fetch('/admin/hide-reply', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ replyId: replyId })
        });
        const data = await response.json();
        if (data.success) {
            alert('✅ Reply hidden successfully!');
            window.location.href = '/admin/flags?type=reply';
        }
    } catch(e) {
        alert('Error hiding reply');
    }
}

async function deleteReply() {
    if (!confirm('Are you sure you want to DELETE this reply? This cannot be undone.')) return;
    try {
        const response = await fetch('/admin/delete-reply', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ replyId: replyId })
        });
        const data = await response.json();
        if (data.success) {
            alert('✅ Reply deleted successfully!');
            window.location.href = '/admin/flags?type=reply';
        }
    } catch(e) {
        alert('Error deleting reply');
    }
}

async function resolveFlag() {
    if (!confirm('Mark this flag as resolved?')) return;
    try {
        const response = await fetch('/admin/resolve-flag', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ flagId: flagId })
        });
        const data = await response.json();
        if (data.success) {
            alert('✅ Flag resolved successfully!');
            window.location.href = '/admin/flags?type=reply';
        }
    } catch(e) {
        alert('Error resolving flag');
    }
}
</script>

<%- include('partials/footer') %>
