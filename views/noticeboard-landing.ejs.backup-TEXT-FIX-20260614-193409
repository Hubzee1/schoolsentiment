<%- include('partials/header') %>

<div class="bg-[#fefbf0] text-slate-900 antialiased min-h-screen relative overflow-x-hidden">
  
  <div class="absolute inset-0 opacity-[0.008] pointer-events-none select-none z-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full min-h-screen" viewBox="0 0 1200 1000" preserveAspectRatio="xMidYMid slice">
      <g stroke="#000" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <g transform="translate(650, 180)"><circle cx="90" cy="90" r="80"/><path d="M60 75 Q75 60 90 75 M100 75 Q115 60 130 75" stroke-width="14"/><path d="M50 105 Q90 150 130 105 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 132 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
      </g>
    </svg>
  </div>

  <div class="relative z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10">
      <header class="max-w-3xl mx-auto text-center px-4 pt-8 pb-6 relative z-10 w-full">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900">
          School <span class="bg-amber-100 px-3 py-1 rounded-md text-amber-900 font-bold text-2xl sm:text-3xl md:text-4xl align-middle inline-block ml-1">Noticeboard</span>
        </h1>
        <p class="mt-3 text-sm sm:text-base text-slate-600 max-w-xl mx-auto leading-relaxed font-medium px-2">
          Buy, sell, and pass on school items. Keep it local, keep it in the community.
        </p>
      </header>

      <!-- SCHOOL SEARCH BAR -->
      <div class="max-w-2xl mx-auto mb-6 px-4">
        <div class="relative">
          <input type="text" id="schoolSearch" placeholder="Search for a school noticeboard..." class="w-full px-4 py-3 pl-11 border border-slate-300 rounded-full shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm">
          <svg class="absolute left-4 top-3.5 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <div id="schoolSearchResults" class="absolute z-20 w-full bg-white border border-slate-200 rounded-xl shadow-lg mt-2 max-h-64 overflow-y-auto hidden"></div>
        </div>
      </div>

      <!-- CATEGORY FILTERS - CENTERED WITH TWO LINES -->
      <div class="max-w-5xl mx-auto px-4 mb-6 relative z-10 w-full">
        <div class="flex flex-wrap justify-center items-center gap-2">
          <a href="?page=1&filter=all&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= (currentFilter === 'all' || !currentFilter) ? 'bg-indigo-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-indigo-50 border border-indigo-100 text-indigo-700 hover:bg-indigo-100' %> px-3 py-1.5 rounded-full text-xs font-semibold transition-all">All</a>
          <a href="?page=1&filter=uniform&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'uniform' ? 'bg-indigo-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-indigo-50 border border-indigo-100 text-indigo-700 hover:bg-indigo-100' %> px-3 py-1.5 rounded-full text-xs font-semibold transition-all">Uniforms</a>
          <a href="?page=1&filter=books&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'books' ? 'bg-blue-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-blue-50 border border-blue-100 text-blue-700 hover:bg-blue-100' %> px-3 py-1.5 rounded-full text-xs font-semibold transition-all">Books</a>
          <a href="?page=1&filter=sports&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'sports' ? 'bg-green-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-green-100 border border-green-300 text-green-800 hover:bg-green-200' %> px-3 py-1.5 rounded-full text-xs font-semibold transition-all">Sports</a>
          <a href="?page=1&filter=other&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'other' ? 'bg-purple-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-purple-50 border border-purple-100 text-purple-700 hover:bg-purple-100' %> px-3 py-1.5 rounded-full text-xs font-semibold transition-all">Other</a>
          <a href="?page=1&filter=free&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'free' ? 'bg-emerald-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-emerald-50 border border-emerald-200 text-emerald-700 hover:bg-emerald-100' %> px-3 py-1.5 rounded-full text-xs font-semibold transition-all">Free</a>
          <a href="?page=1&filter=wanted&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'wanted' ? 'bg-amber-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-amber-50 border border-amber-200 text-amber-700 hover:bg-amber-100' %> px-3 py-1.5 rounded-full text-xs font-semibold transition-all">Wanted</a>
          <a href="?page=1&filter=schools&sort=<%= currentSort || 'newest' %>" class="filter-btn whitespace-nowrap <%= currentFilter === 'schools' ? 'bg-slate-600 text-white ring-2 ring-indigo-500 ring-offset-2' : 'bg-slate-100 border border-slate-200 text-slate-700 hover:bg-slate-200' %> px-3 py-1.5 rounded-full text-xs font-semibold transition-all">Schools Only</a>
        </div>
      </div>

      <!-- SORT OPTIONS - CENTERED DROPDOWN -->
      <div class="max-w-5xl mx-auto px-4 mb-6">
        <div class="flex justify-center items-center">
          <div class="relative">
            <select id="sortSelect" class="appearance-none bg-white border border-slate-300 rounded-full px-5 py-2 pr-10 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 cursor-pointer">
              <option value="newest" <%= currentSort === 'newest' || !currentSort ? 'selected' : '' %>>Sort: Newest</option>
              <option value="price-low" <%= currentSort === 'price-low' ? 'selected' : '' %>>Sort: Price: Low to High</option>
              <option value="price-high" <%= currentSort === 'price-high' ? 'selected' : '' %>>Sort: Price: High to Low</option>
            </select>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
              <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- ADS GRID -->
      <div class="max-w-7xl mx-auto px-4">
        <% if (ads && ads.length > 0) { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
            <% ads.forEach(ad => { %>
              <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-md transition-all">
                <a href="/ad/<%= ad.id %>" class="block">
                  <div class="h-40 sm:h-44 bg-slate-100 overflow-hidden relative">
                    <% if (ad.imageUrl) { %>
                      <img src="<%= ad.imageUrl %>" alt="<%= ad.title %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center text-slate-300">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                        </svg>
                      </div>
                    <% } %>
                    <% if (ad.isWanted) { %>
                      <span class="absolute top-2 left-2 bg-amber-500 text-white text-xs font-bold px-2 py-0.5 rounded-full">WANTED</span>
                    <% } %>
                  </div>
                  <div class="p-4">
                    <div class="flex justify-between items-start gap-2">
                      <h3 class="font-bold text-slate-900 text-sm sm:text-base line-clamp-1"><%= ad.title %></h3>
                      <span class="text-sm font-black text-slate-900 shrink-0"><%= ad.isFree ? 'FREE' : '£' + ad.price %></span>
                    </div>
                    <p class="text-xs text-slate-500 mt-1 line-clamp-2"><%= ad.description ? ad.description.substring(0, 80) : '' %><%= ad.description && ad.description.length > 80 ? '...' : '' %></p>
                    <div class="mt-3 flex justify-between items-center">
                      <div class="flex items-center gap-1">
                        <span class="text-xs text-slate-400"><%= ad.schoolName %></span>
                        <% if (ad.isSchoolVerified) { %>
                          <svg class="w-3 h-3 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>
                        <% } %>
                      </div>
                      <span class="text-xs text-slate-400"><%= new Date(ad.createdAt).toLocaleDateString('en-GB') %></span>
                    </div>
                    <div class="mt-3 flex justify-between items-center">
                      <span class="text-xs font-medium text-slate-400">Ref: <%= ad.publicId %></span>
                      <a href="/ad/<%= ad.id %>" class="text-xs font-bold text-indigo-600 hover:text-indigo-800">View Details →</a>
                    </div>
                  </div>
                </a>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="bg-white rounded-2xl p-8 text-center border border-slate-200">
            <p class="text-slate-500">No items found in this category.</p>
          </div>
        <% } %>
      </div>

      <!-- PAGINATION -->
      <% if (pagination.totalPages > 1) { %>
        <div class="flex justify-center items-center gap-2 mt-8 pb-8 flex-wrap">
          <% if (pagination.currentPage > 1) { %>
            <a href="?page=<%= pagination.currentPage - 1 %>&filter=<%= currentFilter || 'all' %>&sort=<%= currentSort || 'newest' %>" class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50">← Previous</a>
          <% } %>
          <span class="px-3 py-1.5 text-sm text-slate-600">Page <%= pagination.currentPage %> of <%= pagination.totalPages %></span>
          <% if (pagination.currentPage < pagination.totalPages) { %>
            <a href="?page=<%= pagination.currentPage + 1 %>&filter=<%= currentFilter || 'all' %>&sort=<%= currentSort || 'newest' %>" class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50">Next →</a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
// School search autocomplete
const searchInput = document.getElementById('schoolSearch');
const resultsDiv = document.getElementById('schoolSearchResults');
let schools = [];

fetch('/api/schools')
    .then(res => res.json())
    .then(data => { schools = data; });

if (searchInput) {
    searchInput.addEventListener('input', function() {
        const query = this.value.trim().toLowerCase();
        if (query.length < 2) {
            resultsDiv.classList.add('hidden');
            return;
        }
        const matches = schools.filter(s => s.name.toLowerCase().includes(query) || s.town.toLowerCase().includes(query)).slice(0, 8);
        if (matches.length === 0) {
            resultsDiv.classList.add('hidden');
            return;
        }
        let html = '';
        matches.forEach(school => {
            html += `<div class="p-3 hover:bg-slate-50 cursor-pointer border-b border-slate-100 last:border-0" data-school="${encodeURIComponent(school.name)}">
                        <div class="font-semibold text-slate-800 text-sm">${school.name}</div>
                        <div class="text-xs text-slate-500">${school.town} • ${school.postcode}</div>
                    </div>`;
        });
        resultsDiv.innerHTML = html;
        resultsDiv.classList.remove('hidden');
        
        document.querySelectorAll('[data-school]').forEach(el => {
            el.addEventListener('click', function() {
                window.location.href = '/school/' + this.dataset.school + '/noticeboard';
            });
        });
    });
    
    document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !resultsDiv.contains(e.target)) {
            resultsDiv.classList.add('hidden');
        }
    });
}

// Sort dropdown handler
const sortSelect = document.getElementById('sortSelect');
if (sortSelect) {
    sortSelect.addEventListener('change', function() {
        const currentUrl = new URL(window.location.href);
        currentUrl.searchParams.set('sort', this.value);
        currentUrl.searchParams.set('page', '1');
        window.location.href = currentUrl.toString();
    });
}
</script>

<%- include('partials/footer') %>
