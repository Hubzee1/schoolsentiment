<%- include('partials/header') %>

<div class="bg-[#fefbf0] text-slate-900 antialiased min-h-screen flex flex-col relative overflow-x-hidden">
  
  <!-- FAINT BACKGROUND FACES - SOLID BLACK -->
  <div class="absolute inset-0 opacity-[0.015] pointer-events-none select-none z-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full min-h-screen" viewBox="0 0 1200 1000" preserveAspectRatio="xMidYMid slice">
      <g stroke="#000" stroke-width="16" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <g transform="translate(650, 180)"><circle cx="90" cy="90" r="80"/><path d="M60 75 Q75 60 90 75 M100 75 Q115 60 130 75" stroke-width="16"/><path d="M50 105 Q90 150 130 105 Z" fill="#000"/></g>
        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="12"/><path d="M40 80 Q70 115 100 80 Z" fill="#000"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="8" fill="#000"/><circle cx="100" cy="68" r="8" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="6" fill="#000"/><circle cx="77" cy="52" r="6" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="8" fill="#000"/><circle cx="100" cy="68" r="8" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="12"/><path d="M40 80 Q70 115 100 80 Z" fill="#000"/></g>
        <g transform="translate(250, 680)"><circle cx="110" cy="110" r="98"/><path d="M70 95 Q90 75 110 95 M120 95 Q140 75 160 95" stroke-width="16"/><path d="M55 135 Q110 195 165 135 Z" fill="#000"/></g>
        <g transform="translate(710, 700)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="6" fill="#000"/><circle cx="77" cy="52" r="6" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(940, 740)"><circle cx="85" cy="85" r="76"/><path d="M55 75 Q70 60 85 75 M95 75 Q110 60 125 75" stroke-width="14"/><path d="M48 110 Q85 155 122 110 Z" fill="#000"/></g>
      </g>
    </svg>
  </div>

  <div class="relative z-10 flex-grow flex items-center justify-center px-4 py-8">
    <div class="max-w-2xl w-full bg-white rounded-3xl shadow-xl border border-slate-200 p-8 sm:p-12 text-center">
      
      <div class="text-6xl mb-4 animate-pulse">❤️</div>
      
      <h1 class="text-3xl sm:text-4xl font-black text-slate-900 tracking-tight mb-3">
        Thank You for Your Review!
      </h1>
      
      <p class="text-slate-600 text-base sm:text-lg mb-2">
        Your anonymous review has been submitted successfully.
      </p>
      
      <p class="text-slate-500 text-sm mb-6">
        Your voice helps other families make informed decisions about schools.
      </p>
      
      <div class="border-t border-slate-200 pt-6 mt-4">
        <p class="text-slate-700 font-semibold text-sm mb-4">
          🙌 Want to do more?
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/noticeboard" class="bg-amber-400 hover:bg-amber-500 text-slate-950 font-semibold px-5 py-2.5 rounded-full text-sm transition-all">📦 Browse Noticeboard</a>
          <a href="/school/<%= schoolName %>" class="bg-black hover:bg-slate-800 text-white font-semibold px-5 py-2.5 rounded-full text-sm transition-all">📖 View School</a>
          <a href="/" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold px-5 py-2.5 rounded-full text-sm transition-all">🏠 Home</a>
        </div>
      </div>
      
      <div class="border-t border-slate-200 pt-6 mt-6">
        <p class="text-slate-500 text-sm">
          💬 Know someone with a school experience to share?<br>
          <span class="text-xs text-slate-400">Tell them about School Sentiment!</span>
        </p>
      </div>
      
      <div class="mt-6 pt-4 border-t border-slate-200">
        <p class="text-xs text-slate-400">
          Your review is anonymous. No personal information is stored.
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
