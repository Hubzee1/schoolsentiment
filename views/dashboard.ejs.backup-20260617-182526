<%- include('partials/header') %>

<div class="bg-[#fefbf0] text-slate-900 antialiased min-h-screen flex flex-col relative overflow-x-hidden">

  <div class="absolute inset-0 opacity-[0.008] pointer-events-none select-none z-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 1200 1000" preserveAspectRatio="xMidYMid slice">
      <g stroke="#000" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <g transform="translate(650, 180)"><circle cx="90" cy="90" r="80"/><path d="M60 75 Q75 60 90 75 M100 75 Q115 60 130 75" stroke-width="14"/><path d="M50 105 Q90 150 130 105 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(180, 80)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(920, 90)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 130 102 112"/></g>
        <g transform="translate(100, 380)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(480, 420)"><circle cx="78" cy="78" r="70"/><circle cx="56" cy="68" r="6" fill="#000"/><circle cx="100" cy="68" r="6" fill="#000"/><path d="M54 112 Q78 132 102 112"/></g>
        <g transform="translate(880, 440)"><circle cx="70" cy="70" r="62"/><path d="M45 55 Q57 43 70 55 M75 55 Q87 43 100 55" stroke-width="10"/><path d="M40 80 Q70 115 100 80 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(250, 680)"><circle cx="110" cy="110" r="98"/><path d="M70 95 Q90 75 110 95 M120 95 Q140 75 160 95" stroke-width="16"/><path d="M55 135 Q110 195 165 135 Z" fill="#000" opacity="0.15"/></g>
        <g transform="translate(710, 700)"><circle cx="60" cy="60" r="54"/><circle cx="43" cy="52" r="5" fill="#000"/><circle cx="77" cy="52" r="5" fill="#000"/><path d="M42 82 Q60 98 78 82"/></g>
        <g transform="translate(940, 740)"><circle cx="85" cy="85" r="76"/><path d="M55 75 Q70 60 85 75 M95 75 Q110 60 125 75" stroke-width="12"/><path d="M48 110 Q85 155 122 110 Z" fill="#000" opacity="0.15"/></g>
      </g>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-6 sm:pt-8 w-full relative z-10">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end border-b border-slate-200 pb-4 sm:pb-5 gap-3">
      <div>
        <h1 class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tight">My Dashboard</h1>
        <p class="text-xs text-slate-500 mt-1 font-medium">Your centralized overview for local reviews and noticeboard tracking.</p>
      </div>
      <div class="text-left sm:text-right">
        <% if (user && user.isSchoolStaff === 1 && schoolRepresentative) { %>
          <a href="/edit-school-profile/<%= encodeURIComponent(schoolRepresentative) %>" class="text-[11px] bg-slate-100 text-slate-600 px-3 py-1.5 rounded-full font-semibold border border-slate-200 hover:bg-slate-200 transition inline-block mr-0 sm:mr-2 mb-2 sm:mb-0">
            Profile: <strong class="text-slate-900 font-bold"><%= schoolRepresentative %></strong>
          </a>
        <% } %>
        <a href="/account" class="text-[11px] bg-slate-100 text-slate-600 px-3 py-1.5 rounded-full font-semibold border border-slate-200 hover:bg-slate-200 transition inline-block">
          Account: <strong class="text-slate-900 font-bold truncate max-w-[150px] sm:max-w-none inline-block align-middle"><%= user.email %></strong>
        </a>
      </div>
    </div>
  </div>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-10 w-full relative z-10 flex-grow">
    <div class="flex flex-col lg:flex-row gap-6 lg:gap-10">
      
      <div class="flex-1 space-y-6">
        
        <section class="bg-white rounded-2xl border border-slate-200 p-4 sm:p-5 shadow-sm">
          <div class="flex justify-between items-center mb-4">
            <div class="flex items-center gap-2">
              <h2 class="text-base sm:text-lg font-black text-slate-900 tracking-tight">My Reviews</h2>
              <span class="bg-slate-900 text-white text-[10px] font-extrabold px-2 py-0.5 rounded-full"><%= userReviews.length %></span>
            </div>
            <a href="/review" class="bg-black hover:bg-slate-800 text-white text-[11px] font-bold px-3 py-1.5 rounded-full transition-all">+ Write Review</a>
          </div>
          <% if (userReviews.length === 0) { %>
            <div class="border border-slate-200 border-dashed rounded-xl p-6 text-center">
              <p class="text-xs font-semibold text-slate-700">No reviews yet</p>
              <p class="text-[11px] text-slate-400 mt-1">Share your experience with a school.</p>
            </div>
          <% } else { %>
            <div class="space-y-3">
              <% userReviews.slice(0, 3).forEach(review => { %>
                <div class="border-b border-slate-100 pb-3 last:border-0 last:pb-0">
                  <div class="flex justify-between items-start">
                    <div>
                      <h3 class="font-bold text-slate-900 text-sm"><%= review.schoolName %></h3>
                      <p class="text-[10px] text-slate-400 mt-0.5"><%= new Date(review.createdAt).toLocaleDateString('en-GB') %></p>
                    </div>
                    <div class="flex gap-1">
                      <a href="/edit-review/<%= review.id %>" class="text-[10px] font-bold text-slate-600 bg-slate-50 border border-slate-200 px-2 py-1 rounded-md">Edit</a>
                      <form action="/delete-review/<%= review.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this review?');">
                        <button type="submit" class="text-[10px] font-bold text-rose-600 bg-rose-50 border border-rose-100 px-2 py-1 rounded-md">Delete</button>
                      </form>
                    </div>
                  </div>
                  <p class="text-xs text-slate-600 mt-2 line-clamp-2"><%= review.reviewText ? review.reviewText.substring(0, 100) : '' %>...</p>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

        <section class="bg-white rounded-2xl border border-slate-200 p-4 sm:p-5 shadow-sm">
          <div class="flex items-center gap-2 mb-4">
            <h2 class="text-base sm:text-lg font-black text-slate-900 tracking-tight">Saved School Reviews</h2>
            <span class="bg-indigo-100 text-indigo-900 text-[10px] font-extrabold px-2 py-0.5 rounded-full"><%= totalSavedCount || 0 %></span>
          </div>
          <% if (!savedReviewsGrouped || Object.keys(savedReviewsGrouped).length === 0) { %>
            <div class="border border-slate-200 border-dashed rounded-xl p-6 text-center">
              <p class="text-xs font-semibold text-slate-700">No saved reviews</p>
              <p class="text-[11px] text-slate-400 mt-1">Click ❤️ on any review to save it here.</p>
            </div>
          <% } else { %>
            <div class="space-y-3">
              <% Object.keys(savedReviewsGrouped).slice(0, 3).forEach(schoolName => { %>
                <div class="border border-slate-200 rounded-xl p-3">
                  <div class="flex justify-between items-center">
                    <div>
                      <h3 class="font-bold text-slate-900 text-sm"><%= schoolName %></h3>
                      <p class="text-xs text-slate-500 mt-0.5"><%= savedReviewsGrouped[schoolName].length %> saved reviews</p>
                    </div>
                    <a href="/saved-reviews" class="text-xs font-bold text-indigo-600">View all →</a>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

        <section class="bg-white rounded-2xl border border-slate-200 p-4 sm:p-5 shadow-sm">
          <div class="flex items-center gap-2 mb-4">
            <h2 class="text-base sm:text-lg font-black text-slate-900 tracking-tight">Schools You Follow</h2>
            <span class="bg-green-100 text-green-900 text-[10px] font-extrabold px-2 py-0.5 rounded-full" id="followedSchoolsCount">0</span>
          </div>
          <div id="followedSchoolsList"><div class="text-center py-4"><p class="text-sm text-slate-500">Loading...</p></div></div>
        </section>
      </div>

      <div class="flex-1 space-y-6">
        
        <section class="bg-white rounded-2xl border border-slate-200 p-4 sm:p-5 shadow-sm">
          <div class="flex justify-between items-center mb-4">
            <div class="flex items-center gap-2">
              <h2 class="text-base sm:text-lg font-black text-slate-900 tracking-tight">My Ads</h2>
              <span class="bg-slate-800 text-white text-[10px] font-extrabold px-2 py-0.5 rounded-full"><%= userAds ? userAds.length : 0 %></span>
            </div>
            <a href="/post-ad/" class="bg-amber-400 hover:bg-amber-500 text-slate-950 text-[11px] font-bold px-3 py-1.5 rounded-full transition-all">+ Post Item</a>
          </div>
          <% if (!userAds || userAds.length === 0) { %>
            <div class="border border-slate-200 border-dashed rounded-xl p-6 text-center">
              <p class="text-xs font-semibold text-slate-700">No ads posted yet</p>
              <p class="text-[11px] text-slate-400 mt-1">Go to any school page and click Noticeboard.</p>
            </div>
          <% } else { %>
            <div class="space-y-3">
              <% userAds.slice(0, 3).forEach(ad => { %>
                <div class="border border-slate-200 rounded-xl p-3">
                  <div class="flex gap-3">
                    <div class="w-16 h-16 bg-slate-50 rounded-lg overflow-hidden shrink-0">
                      <% if (ad.imageUrl) { %><img src="<%= ad.imageUrl %>" class="w-full h-full object-cover"><% } else { %><div class="w-full h-full flex items-center justify-center text-slate-300">📷</div><% } %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex justify-between items-start gap-2">
                        <div>
                          <div class="flex items-center gap-2 flex-wrap">
                            <h3 class="font-bold text-slate-900 text-sm truncate"><%= ad.title %></h3>
                            <% if (ad.status === 'sold') { %><span class="bg-green-100 text-green-800 text-[9px] font-extrabold px-2 py-0.5 rounded-full">SOLD</span><% } %>
                            <% if (ad.status === 'sold' && ad.soldAt) { 
                              const soldDate = new Date(ad.soldAt).toLocaleDateString('en-GB');
                              const soldTime = new Date(ad.soldAt).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
                            %><span class="text-[10px] text-green-600 ml-2">Sold on <%= soldDate %> at <%= soldTime %></span><% } %>
                          </div>
                        </div>
                        <span class="text-sm font-black text-slate-900 shrink-0"><%= ad.isFree ? 'FREE' : '£' + ad.price %></span>
                      </div>
                      <p class="text-[11px] text-slate-500 truncate mt-1"><%= ad.schoolName %></p>
                      <div class="flex flex-wrap gap-2 mt-2">
                        <a href="/ad/<%= ad.id %>" class="text-[10px] font-bold text-indigo-600 bg-indigo-50 border border-indigo-100 px-2 py-1 rounded-md">View</a>
                        <a href="/messages?ad=<%= ad.id %>" class="text-[10px] font-bold text-blue-600 bg-blue-50 border border-blue-100 px-2 py-1 rounded-md">Messages</a>
                        <a href="/edit-ad/<%= ad.id %>" class="text-[10px] font-bold text-slate-600 bg-slate-50 border border-slate-200 px-2 py-1 rounded-md">Edit</a>
                        <form action="/delete-ad/<%= ad.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this ad?');"><button type="submit" class="text-[10px] font-bold text-rose-600 bg-rose-50 border border-rose-100 px-2 py-1 rounded-md">Delete</button></form>
                        <% if (ad.status === 'sold') { %>
                          <button onclick="markAdAvailable('<%= ad.id %>', '<%= ad.title.replace(/'/g, "\\'") %>')" class="text-[10px] font-bold text-amber-600 bg-amber-50 border border-amber-200 px-2 py-1 rounded-md">Mark as Available</button>
                        <% } else { %>
                          <button onclick="markAdSold('<%= ad.id %>', '<%= ad.title.replace(/'/g, "\\'") %>')" class="text-[10px] font-bold text-white bg-green-600 hover:bg-green-700 px-2 py-1 rounded-md">Mark as Sold</button>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

        <section class="bg-white rounded-2xl border border-slate-200 p-4 sm:p-5 shadow-sm">
          <div class="flex items-center gap-2 mb-4">
            <h2 class="text-base sm:text-lg font-black text-slate-900 tracking-tight">Saved Ads</h2>
            <span class="bg-amber-100 text-amber-900 text-[10px] font-extrabold px-2 py-0.5 rounded-full" id="savedAdsCount">0</span>
          </div>
          <div id="savedAdsList"><div class="text-center py-4"><p class="text-sm text-slate-500">Loading...</p></div></div>
        </section>
      </div>
    </div>
  </main>
</div>

<script>
async function markAdSold(adId, adTitle) {
    if (!confirm(`Are you sure you want to mark "${adTitle}" as SOLD?\n\nThis item will be removed from noticeboards and buyers will be notified.`)) return;
    try {
        const response = await fetch(`/api/mark-ad-sold/${adId}`, { method: 'POST' });
        const data = await response.json();
        if (data.success) { alert(`✅ "${adTitle}" has been marked as sold.`); window.location.reload(); }
        else { alert(`Error: ${data.error}`); }
    } catch(e) { alert('An error occurred. Please try again.'); }
}

async function markAdAvailable(adId, adTitle) {
    if (!confirm(`Are you sure you want to mark "${adTitle}" as AVAILABLE again?\n\nThis item will reappear on noticeboards.`)) return;
    try {
        const response = await fetch(`/api/mark-ad-available/${adId}`, { method: 'POST' });
        const data = await response.json();
        if (data.success) { alert(`✅ "${adTitle}" is now available again.`); window.location.reload(); }
        else { alert(`Error: ${data.error}`); }
    } catch(e) { alert('An error occurred. Please try again.'); }
}

async function loadSavedAds() {
    try {
        const response = await fetch('/api/saved-ads');
        if (response.ok) {
            const savedAdIds = await response.json();
            document.getElementById('savedAdsCount').innerText = savedAdIds.length;
            const container = document.getElementById('savedAdsList');
            if (savedAdIds.length === 0) {
                container.innerHTML = '<div class="border border-slate-200 border-dashed rounded-xl p-6 text-center"><p class="text-xs font-semibold text-slate-700">No saved ads</p><p class="text-[11px] text-slate-400 mt-1">Click ❤️ on any ad to save it here.</p></div>';
                return;
            }
            const adsResponse = await fetch('/api/ads');
            const allAds = await adsResponse.json();
            const savedAds = allAds.filter(ad => savedAdIds.includes(ad.id));
            let html = '<div class="space-y-3">';
            savedAds.forEach(ad => {
                const isSold = ad.status === 'sold';
                const soldDate = isSold && ad.soldAt ? new Date(ad.soldAt).toLocaleDateString('en-GB') : null;
                const soldTime = isSold && ad.soldAt ? new Date(ad.soldAt).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) : null;
                html += `
                    <div class="border border-slate-200 rounded-xl p-3">
                        <div class="flex gap-3">
                            <div class="w-16 h-16 bg-slate-50 rounded-lg overflow-hidden shrink-0">
                                ${ad.imageUrl ? `<img src="${ad.imageUrl}" class="w-full h-full object-cover">` : '<div class="w-full h-full flex items-center justify-center text-slate-300">📷</div>'}
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex justify-between items-start gap-2">
                                    <div>
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <h3 class="font-bold text-slate-900 text-sm truncate">${escapeHtml(ad.title)}</h3>
                                            ${isSold ? '<span class="bg-green-100 text-green-800 text-[9px] font-extrabold px-2 py-0.5 rounded-full">SOLD</span>' : ''}
                                            ${isSold && soldDate ? `<span class="text-[10px] text-green-600 ml-2">Sold on ${soldDate} at ${soldTime}</span>` : ''}
                                        </div>
                                    </div>
                                    <span class="text-sm font-black text-slate-900 shrink-0">${ad.isFree ? 'FREE' : '£' + ad.price}</span>
                                </div>
                                <p class="text-[11px] text-slate-500 truncate mt-1">${escapeHtml(ad.schoolName)}</p>
                                <div class="flex flex-wrap gap-2 mt-2">
                                    <a href="/ad/${ad.id}" class="text-[10px] font-bold text-indigo-600 bg-indigo-50 border border-indigo-100 px-2 py-1 rounded-md">View</a>
                                    <a href="/messages?ad=${ad.id}" class="text-[10px] font-bold text-blue-600 bg-blue-50 border border-blue-100 px-2 py-1 rounded-md">Messages</a>
                                    <button class="unsave-ad-btn text-[10px] font-bold text-rose-500 bg-rose-50 px-2 py-1 rounded" data-ad-id="${ad.id}">Remove</button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            container.innerHTML = html;
            document.querySelectorAll('.unsave-ad-btn').forEach(btn => btn.addEventListener('click', async () => { await fetch(`/unsave-ad/${btn.dataset.adId}`, { method: 'POST' }); loadSavedAds(); }));
        }
    } catch(e) { console.error(e); }
}

function escapeHtml(text) {
    if (!text) return '';
    return text.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}

async function loadFollowedSchools() {
    try {
        const response = await fetch('/api/followed-schools');
        const data = await response.json();
        const followedSchools = Array.isArray(data) ? data : (data.followedSchools || []);
        document.getElementById('followedSchoolsCount').innerText = followedSchools.length;
        const container = document.getElementById('followedSchoolsList');
        if (followedSchools.length === 0) {
            container.innerHTML = '<div class="border border-slate-200 border-dashed rounded-xl p-4 text-center"><p class="text-xs font-semibold text-slate-700">No followed schools</p><p class="text-[11px] text-slate-400 mt-1">Click "Follow School" on any school profile.</p></div>';
            return;
        }
        let html = '<div class="space-y-2">';
        for (const schoolName of followedSchools) {
            html += `<div class="flex justify-between items-center border-b border-slate-100 pb-2 last:border-0"><a href="/school/${encodeURIComponent(schoolName)}" class="font-bold text-slate-900 text-sm hover:text-indigo-600">${escapeHtml(schoolName)}</a><button onclick="unfollowSchool('${escapeHtml(schoolName).replace(/'/g, "\\'")}')" class="text-xs text-red-600">Unfollow</button></div>`;
        }
        html += '</div>';
        container.innerHTML = html;
    } catch(e) { console.error(e); }
}

async function unfollowSchool(schoolName) {
    await fetch('/api/unfollow-school', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ schoolName }) });
    loadFollowedSchools();
}

document.addEventListener('DOMContentLoaded', () => { loadSavedAds(); loadFollowedSchools(); });
</script>

<%- include('partials/footer') %>
