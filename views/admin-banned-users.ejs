<%- include('partials/header') %>

<main class="max-w-6xl mx-auto px-4 py-8">
    <nav class="text-xs text-slate-500 mb-4 flex space-x-2">
        <a href="/" class="hover:underline">Home</a>
        <span>&gt;</span>
        <a href="/admin/flags" class="hover:underline">Moderation Queue</a>
        <span>&gt;</span>
        <span class="text-slate-800 font-medium">Banned Users</span>
    </nav>

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-slate-900">Banned Users</h1>
        <a href="/admin/flags" class="text-indigo-600 hover:underline text-sm">← Back to Flags</a>
    </div>

    <div id="bannedUsersList" class="space-y-3">
        <div class="text-center text-slate-500 py-8">Loading banned users...</div>
    </div>
</main>

<script>
async function loadBannedUsers() {
    const response = await fetch('/api/banned-users');
    const users = await response.json();
    const container = document.getElementById('bannedUsersList');
    
    if (!users || users.length === 0) {
        container.innerHTML = '<div class="bg-white border border-slate-200 rounded-xl p-8 text-center"><p class="text-slate-500">No banned users</p></div>';
        return;
    }
    
    container.innerHTML = users.map(user => {
        let buttons = '';
        
        if (user.bannedForReviewId) {
            buttons += `<button onclick="viewReason('${user.bannedForReviewId}')" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition">📄 View Reason</button>`;
        }
        buttons += `<button onclick="unbanUser('${user.id}')" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">✓ Unban User</button>`;
        
        return `
            <div class="bg-white border border-slate-200 rounded-xl p-4">
                <div class="flex justify-between items-start">
                    <div class="flex-1">
                        <div class="flex items-center gap-2">
                            <span class="font-bold text-slate-900">${escapeHtml(user.email)}</span>
                            <span class="text-xs text-red-600 bg-red-50 px-2 py-0.5 rounded-full">Banned</span>
                        </div>
                        <p class="text-xs text-slate-400 mt-1">User ID: ${user.id}</p>
                        <p class="text-xs text-slate-400">Banned on: ${user.bannedAt ? new Date(user.bannedAt).toLocaleString() : 'Unknown'}</p>
                        ${user.bannedReason ? `<p class="text-xs text-red-600 bg-red-50 p-2 rounded-md mt-2"><strong>Reason:</strong> ${escapeHtml(user.bannedReason)}</p>` : ''}
                    </div>
                    <div class="flex gap-2 ml-4">
                        ${buttons}
                    </div>
                </div>
            </div>
        `;
    }).join('');
}

async function viewReason(reviewId) {
    window.location.href = '/admin/review/' + reviewId;
}

async function unbanUser(userId) {
    if (confirm('Unban this user? They will be able to post reviews and ads again.')) {
        const response = await fetch('/admin/unban-user-by-id', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId })
        });
        if (response.ok) {
            loadBannedUsers();
        } else {
            alert('Error unbanning user');
        }
    }
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

loadBannedUsers();
</script>

<%- include('partials/footer') %>