<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800;14..32,900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; min-height: 100vh; }
        body { 
            font-family: 'Inter', Arial, sans-serif; 
            background: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .grey-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #f8f9fa;
            z-index: 0;
        }
        .cream-banner {
            border-bottom: 1px solid #e9e9ef;
            position: absolute;
            top: 65px;
            left: 0;
            width: 100%;
            height: 15cm;
            background: #fefbf0;
            z-index: 1;
            overflow: hidden;
        }
        .background-container {
            position: absolute;
            top: 65px;
            left: 0;
            width: 100%;
            height: 15cm;
            z-index: 2;
            pointer-events: none;
            overflow: hidden;
        }
        .background-image {
            position: absolute;
            background-repeat: no-repeat;
            background-position: center center;
            opacity: 0.35;
            width: 300px;
            height: 300px;
            background-size: contain;
        }
        .image-elated {
            background-image: url('/images/Elated.png');
            left: -5%;
            top: 20px;
            animation: moveElated 35s ease-in-out infinite;
        }
        .image-angry {
            background-image: url('/images/Angry.png');
            left: 90%;
            top: -80px;
            animation: moveAngry 30s ease-in-out infinite;
        }
        .image-average {
            background-image: url('/images/Average.png');
            left: 50%;
            top: -200px;
            animation: moveAverage 40s ease-in-out infinite;
        }
        .image-happy {
            background-image: url('/images/happy.png');
            left: 75%;
            top: 300px;
            animation: moveHappy 32s ease-in-out infinite;
        }
        .image-sad {
            background-image: url('/images/Sad.png');
            left: 276px;
            top: 230px;
            animation: moveSad 38s ease-in-out infinite;
        }
        @keyframes moveElated {
            0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1.2); }
            25% { transform: translate(75px, 60px) rotate(45deg) scale(1.2); }
            50% { transform: translate(40px, 125px) rotate(0deg) scale(1.2); }
            75% { transform: translate(-60px, 90px) rotate(-45deg) scale(1.2); }
        }
        @keyframes moveAngry {
            0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1.2) scaleX(-1); }
            25% { transform: translate(-90px, -30px) rotate(-30deg) scale(1.2) scaleX(-1); }
            50% { transform: translate(-50px, 90px) rotate(0deg) scale(1.2) scaleX(-1); }
            75% { transform: translate(75px, -40px) rotate(30deg) scale(1.2) scaleX(-1); }
        }
        @keyframes moveAverage {
            0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1.2); }
            33% { transform: translate(60px, 100px) rotate(60deg) scale(1.2); }
            66% { transform: translate(-70px, 75px) rotate(-60deg) scale(1.2); }
        }
        @keyframes moveHappy {
            0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1.2) scaleX(-1); }
            20% { transform: translate(-80px, 40px) rotate(-36deg) scale(1.2) scaleX(-1); }
            40% { transform: translate(50px, 110px) rotate(0deg) scale(1.2) scaleX(-1); }
            60% { transform: translate(-40px, 80px) rotate(36deg) scale(1.2) scaleX(-1); }
            80% { transform: translate(70px, -20px) rotate(0deg) scale(1.2) scaleX(-1); }
        }
        @keyframes moveSad {
            0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1.2); }
            25% { transform: translate(30px, 80px) rotate(45deg) scale(1.2); }
            50% { transform: translate(-40px, 120px) rotate(0deg) scale(1.2); }
            75% { transform: translate(20px, 150px) rotate(-45deg) scale(1.2); }
        }
        .main-content {
            flex: 1;
            position: relative;
            z-index: 10;
        }
        .top-nav {
            background: #000000;
            padding: 0.8rem 0;
            border-bottom: 1px solid #333333;
            position: relative;
            z-index: 20;
        }
        .top-nav .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo img {
            height: 65px;
            width: auto;
        }
        .nav-links {
            display: flex;
            gap: 1.5rem;
            align-items: center;
            font-size: 1rem;
        }
        .top-nav a {
            color: white;
            text-decoration: none;
            opacity: 0.9;
        }
        .top-nav a:hover {
            opacity: 1;
        }
        .nav-divider {
            color: rgba(255,255,255,0.5);
        }
        .container { 
            max-width: 1200px; 
            margin: 0 auto; 
            padding: 0 20px; 
        }
    </style>
</head>
<body>
    <div class="grey-overlay"></div>
    
    <% if (currentPage === 'home') { %>
    <div class="cream-banner"></div>
    <div class="background-container">
        <div class="background-image image-elated"></div>
        <div class="background-image image-angry"></div>
        <div class="background-image image-average"></div>
        <div class="background-image image-happy"></div>
        <div class="background-image image-sad"></div>
    </div>
    <% } %>
    
    <nav class="top-nav">
        <div class="container">
            <div class="logo">
                <a href="/">
                    <img src='/logo/SchoolSentiment_white_transparency.png' alt="SchoolSentiment Logo">
                </a>
            </div>
            <div class="nav-links">
                <a href="/review">Write Review</a>
                <span class="nav-divider">|</span>
                <a href="/noticeboard">Noticeboard</a>
                <span class="nav-divider">|</span>
                <% if (locals.currentUser) { %>
                    <a href="/dashboard">Dashboard</a>
                    <span class="nav-divider">|</span>
                    <a href="/messages">Messages</a>
                    <span class="nav-divider">|</span>
                    <a href="/blog">Blog</a>
                    <span class="nav-divider">|</span>
                    <button id="notificationBellBtn" class="text-white hover:text-gray-300 transition focus:outline-none relative">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                        <span id="notificationBadge" class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold rounded-full min-w-[16px] h-4 flex items-center justify-center px-1 hidden">0</span>
                    </button>
                    <span class="nav-divider">|</span>
                    <% if (locals.currentUser && locals.currentUser.email === 'hubzy@hotmail.com') { %>
                        <a href="/admin/flags">Admin</a>
                        <span class="nav-divider">|</span>
                    <% } %>
                    <a href="/signout">Sign Out</a>
                <% } else { %>
                    <a href="/blog">Blog</a>
                    <span class="nav-divider">|</span>
                    <a href="/signin">Sign In</a>
                <% } %>
            </div>
        </div>
    </nav>
    
    <div class="main-content">

<!-- Slide-out Notification Panel -->
<div id="notificationPanel" class="absolute right-0 w-96 bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out z-[10000] flex flex-col" style="top: 65px; padding-bottom: 100px;">
  <div class="flex justify-between items-center p-4 border-b border-slate-200">
    <h2 class="text-lg font-bold text-slate-900">Notifications</h2>
    <button onclick="closeNotificationPanel()" class="text-slate-400 hover:text-slate-600 transition">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <div id="notificationListPanel" class="flex-1 overflow-y-auto divide-y divide-slate-100">
    <div class="p-4 text-center text-slate-500">Loading notifications...</div>
  </div>
  <div class="p-3 border-t border-slate-200 text-center">
    <button onclick="markAllNotificationsReadPanel()" class="text-sm text-indigo-600 hover:underline">Mark all as read</button>
  </div>
</div>

<!-- Overlay -->
<div id="notificationOverlay" class="absolute bg-black bg-opacity-50 hidden z-[9999]" style="top: 0; left: 0; right: 0; bottom: 0;" onclick="closeNotificationPanel()"></div>

<style>
  #notificationPanel.open {
    transform: translateX(0);
  }
</style>

<script>
let panelOpen = false;

function openNotificationPanel() {
  const panel = document.getElementById('notificationPanel');
  const overlay = document.getElementById('notificationOverlay');
  panel.classList.add('open');
  overlay.classList.remove('hidden');
  panelOpen = true;
  loadNotificationsPanel();
}

function closeNotificationPanel() {
  const panel = document.getElementById('notificationPanel');
  const overlay = document.getElementById('notificationOverlay');
  panel.classList.remove('open');
  overlay.classList.add('hidden');
  panelOpen = false;
}

async function loadNotificationsPanel() {
  try {
    const response = await fetch('/api/notifications?limit=50');
    const data = await response.json();
    const container = document.getElementById('notificationListPanel');
    
    if (!data.notifications || data.notifications.length === 0) {
      container.innerHTML = '<div class="p-8 text-center text-slate-500">✨ You\'re all caught up!</div>';
      return;
    }
    
    let html = '';
    let unreadCount = 0;
    for (const notif of data.notifications) {
      if (!notif.isRead) unreadCount++;
      const notifClass = notif.isRead ? 'bg-white' : 'bg-indigo-50';
      let link = '';
      if (notif.type === 'review' && notif.reviewId) {
        link = `/school/${encodeURIComponent(notif.schoolName)}#review-${notif.reviewId}`;
      } else if (notif.type === 'ad' && notif.adId) {
        link = `/ad/${notif.adId}`;
      } else {
        link = `/school/${encodeURIComponent(notif.schoolName)}`;
      }
      html += `
        <div class="${notifClass} p-4 hover:bg-slate-50 transition cursor-pointer" onclick="markNotificationReadPanel(${notif.id}, '${link}')">
          <p class="text-sm font-medium text-slate-900">${escapeHtmlForNotif(notif.message)}</p>
          <p class="text-xs text-slate-500 mt-1">${escapeHtmlForNotif(notif.schoolName)}</p>
          <p class="text-xs text-slate-400 mt-1">${new Date(notif.createdAt).toLocaleString()}</p>
        </div>
      `;
    }
    container.innerHTML = html;
    
    // Update badge count
    const badge = document.getElementById('notificationBadge');
    if (unreadCount > 0) {
      badge.textContent = unreadCount > 99 ? '99+' : unreadCount;
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  } catch (error) {
    console.error('Error loading notifications:', error);
    document.getElementById('notificationListPanel').innerHTML = '<div class="p-8 text-center text-red-500">Error loading notifications</div>';
  }
}

async function markNotificationReadPanel(notificationId, link) {
  try {
    await fetch('/api/notifications/mark-read', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ notificationId: notificationId })
    });
    loadNotificationsPanel();
    window.location.href = link;
  } catch (error) {
    console.error('Error marking notification read:', error);
  }
}

async function markAllNotificationsReadPanel() {
  try {
    await fetch('/api/notifications/mark-all-read', { method: 'POST' });
    loadNotificationsPanel();
    const badge = document.getElementById('notificationBadge');
    badge.classList.add('hidden');
  } catch (error) {
    console.error('Error marking all notifications read:', error);
  }
}

function escapeHtmlForNotif(text) {
  if (!text) return '';
  return text.replace(/[&<>]/g, function(m) {
    if (m === '&') return '&amp;';
    if (m === '<') return '&lt;';
    if (m === '>') return '&gt;';
    return m;
  });
}

// Close panel when pressing Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && panelOpen) {
    closeNotificationPanel();
  }
});

// Attach click handler to bell button
document.addEventListener('DOMContentLoaded', function() {
  const bellBtn = document.getElementById('notificationBellBtn');
  if (bellBtn) {
    bellBtn.addEventListener('click', openNotificationPanel);
  }
});
</script>

