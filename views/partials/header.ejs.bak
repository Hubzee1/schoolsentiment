<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'SchoolSentiment' %></title>
    <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        
        body { 
            font-family: Arial, sans-serif; 
            background: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }
        
        /* Cream Banner - AT TOP below header - will CLIP the animated images */
        .cream-banner {
            position: absolute;
            top: 65px; /* Below the header (header is ~65px tall) */
            left: 0;
            width: 100%;
            height: 15cm; /* 15cm high */
            background: #fefbf0; /* Cream color */
            z-index: -1; /* Above animated images to create clipping effect */
            margin: 0;
            padding: 0;
            border: none;
            /* Add clipping to hide images outside cream area */
            overflow: hidden;
        }
        
        /* Background image container - INSIDE cream banner */
        .background-container {
            position: absolute;
            top: 0; /* Inside the cream banner */
            left: 0;
            width: 100%;
            height: 15cm; /* Same height as cream banner */
            z-index: -2; /* Below cream banner but images will show through */
            pointer-events: none;
            overflow: visible;
        }
        
        /* Base background image styles - 300px */
        .background-image {
            position: absolute;
            background-repeat: no-repeat;
            background-position: center center;
            opacity: 0.7;
            width: 300px;
            height: 300px;
            background-size: contain;
        }
        
        /* Individual image positioning - ADJUSTED Sad and Average */
        .image-elated {
            background-image: url('/images/Elated.png');
            left: -5%;
            top: 20px;
            animation: moveElated 35s ease-in-out infinite;
        }
        
        .image-angry {
            background-image: url('/images/Angry.png');
            left: 90%;
            top: 120px;
            animation: moveAngry 30s ease-in-out infinite;
        }
        
        .image-average {
            background-image: url('/images/Average.png');
            left: 50%;
            top: 0px; /* CHANGED: from -113px to 0px */
            animation: moveAverage 40s ease-in-out infinite;
        }
        
        .image-happy {
            background-image: url('/images/happy.png');
            left: 65%;
            top: 300px;
            animation: moveHappy 32s ease-in-out infinite;
        }
        
        .image-sad {
            background-image: url('/images/Sad.png');
            left: 15%; /* CHANGED: from 20% to 15% */
            top: 180px;
            animation: moveSad 38s ease-in-out infinite;
        }
        
        /* Movement animations */
        @keyframes moveElated {
            0%, 100% { 
                transform: translate(0, 0) rotate(0deg) scale(1.2); 
            }
            25% { 
                transform: translate(75px, 60px) rotate(45deg) scale(1.2); 
            }
            50% { 
                transform: translate(40px, 125px) rotate(0deg) scale(1.2); 
            }
            75% { 
                transform: translate(-60px, 90px) rotate(-45deg) scale(1.2); 
            }
        }
        
        @keyframes moveAngry {
            0%, 100% { 
                transform: translate(0, 0) rotate(0deg) scale(1.2) scaleX(-1); 
            }
            25% { 
                transform: translate(-90px, -30px) rotate(-30deg) scale(1.2) scaleX(-1); 
            }
            50% { 
                transform: translate(-50px, 90px) rotate(0deg) scale(1.2) scaleX(-1); 
            }
            75% { 
                transform: translate(75px, -40px) rotate(30deg) scale(1.2) scaleX(-1); 
            }
        }
        
        @keyframes moveAverage {
            0%, 100% { 
                transform: translate(0, 0) rotate(0deg) scale(1.2); 
            }
            33% { 
                transform: translate(60px, 100px) rotate(60deg) scale(1.2); 
            }
            66% { 
                transform: translate(-70px, 75px) rotate(-60deg) scale(1.2); 
            }
        }
        
        @keyframes moveHappy {
            0%, 100% { 
                transform: translate(0, 0) rotate(0deg) scale(1.2) scaleX(-1); 
            }
            20% { 
                transform: translate(-80px, 40px) rotate(-36deg) scale(1.2) scaleX(-1); 
            }
            40% { 
                transform: translate(50px, 110px) rotate(0deg) scale(1.2) scaleX(-1); 
            }
            60% { 
                transform: translate(-40px, 80px) rotate(36deg) scale(1.2) scaleX(-1); 
            }
            80% { 
                transform: translate(70px, -20px) rotate(0deg) scale(1.2) scaleX(-1); 
            }
        }
        
        @keyframes moveSad {
            0%, 100% { 
                transform: translate(0, 0) rotate(0deg) scale(1.2); 
            }
            25% { 
                transform: translate(30px, 80px) rotate(45deg) scale(1.2);
            }
            50% { 
                transform: translate(-40px, 120px) rotate(0deg) scale(1.2);
            }
            75% { 
                transform: translate(20px, 150px) rotate(-45deg) scale(1.2);
            }
        }
        
        .main-content {
            flex: 1 0 auto;
            position: relative;
            z-index: 1;
        }
        
        .site-footer {
            flex-shrink: 0;
            position: relative;
            z-index: 1;
        }
        
        /* CHANGED TO BLACK */
        .top-nav {
            background: #000000;
            padding: 0.8rem 0;
            border-bottom: 1px solid #333333;
            position: relative;
            z-index: 3; /* Highest z-index to stay above everything */
        }
        .top-nav .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            display: flex;
            align-items: center;
        }
        .logo img {
            height: 65px;
            width: auto;
        }
        .logo a {
            display: flex;
            align-items: center;
            text-decoration: none;
        }
        .nav-links {
            display: flex;
            gap: 1.5rem;
            align-items: center;
            font-size: 1rem;
        }
        .top-nav a {
            color: white;
            text-decoration: none;
            opacity: 0.9;
        }
        .top-nav a:hover {
            opacity: 1;
        }
        .nav-divider {
            color: rgba(255,255,255,0.5);
            font-size: 0.9rem;
        }
        .container { 
            max-width: 1200px; 
            margin: 0 auto; 
            padding: 0 20px; 
            position: relative;
            z-index: 1;
        }
    </style>
</head>
<body>
    <!-- Cream Banner - AT TOP below header - ACTS AS CLIPPING MASK -->
    <div class="cream-banner">
        <!-- Background Container with animated images - INSIDE cream banner -->
        <div class="background-container">
            <!-- Five images - WITH UPDATED Sad and Average positions -->
            <div class="background-image image-elated"></div>
            <div class="background-image image-angry"></div>
            <div class="background-image image-average"></div>
            <div class="background-image image-happy"></div>
            <div class="background-image image-sad"></div>
        </div>
    </div>
    
    <!-- Top Navigation Bar - NOW BLACK -->
    <nav class="top-nav">
        <div class="container">
            <div class="logo">
                <a href="/">
                    <img src="/logo/SchoolSentiment_white_transparency.png" alt="SchoolSentiment Logo">
                </a>
            </div>
            <div class="nav-links">
                <a href="/review">Write Review</a>
                <span class="nav-divider">|</span>
                <a href="/blog">Blog</a>
                <span class="nav-divider">|</span>
                <a href="/signin">Sign In</a>
            </div>
        </div>
    </nav>
    
    <div class="main-content">

<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('Sad moved to 15%, Average moved to 0px');
});
</script>
