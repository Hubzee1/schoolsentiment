<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 py-8 flex-grow">
    <h1 class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tight mb-6">Admin Dashboard</h1>

    <!-- Analytics Dashboard -->
    <div id="analytics-container">
        <div class="text-center text-slate-500 py-8">Loading analytics...</div>
    </div>
</main>

<script>
async function loadAnalytics() {
    try {
        const response = await fetch('/api/admin/analytics');
        const data = await response.json();
        
        if (data.success) {
            renderAnalytics(data.data);
        } else {
            document.getElementById('analytics-container').innerHTML = '<div class="text-center text-red-500 py-8">Error loading analytics</div>';
        }
    } catch (error) {
        console.error('Error loading analytics:', error);
        document.getElementById('analytics-container').innerHTML = '<div class="text-center text-red-500 py-8">Error loading analytics</div>';
    }
}

function renderAnalytics(stats) {
    const container = document.getElementById('analytics-container');
    
    const html = `
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-500">Total Schools</span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" /></svg>
                </div>
                <div class="text-3xl font-bold text-slate-900">${stats.totalSchools.toLocaleString()}</div>
                <p class="text-xs text-slate-400 mt-1">UK schools in database</p>
            </div>
            
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-500">School Staff</span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                </div>
                <div class="text-3xl font-bold text-slate-900">${stats.schoolStaff.toLocaleString()}</div>
                <p class="text-xs text-slate-400 mt-1">Registered school staff accounts</p>
            </div>
            
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-500">Total Users</span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 0 0-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 0 1 5.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 0 1 9.288 0M15 7a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" /></svg>
                </div>
                <div class="text-3xl font-bold text-slate-900">${stats.totalUsers.toLocaleString()}</div>
                <p class="text-xs text-slate-400 mt-1">Total registered users</p>
            </div>
            
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-500">Verified Schools</span>
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>
                </div>
                <div class="text-3xl font-bold text-slate-900">${stats.verifiedSchools.toLocaleString()}</div>
                <p class="text-xs text-slate-400 mt-1">Schools with verified badge</p>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-500">Total Reviews</span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0l-4.725 2.885a.562.562 0 0 1-.84-.61l1.285-5.385a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5z" /></svg>
                </div>
                <div class="text-3xl font-bold text-slate-900">${stats.totalReviews.toLocaleString()}</div>
                <p class="text-xs text-slate-400 mt-1">Total reviews submitted</p>
            </div>
            
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-500">Active Ads</span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6.5M17 13l1.5 6.5M9 21h6M12 17v4" /></svg>
                </div>
                <div class="text-3xl font-bold text-slate-900">${stats.totalAds.toLocaleString()}</div>
                <p class="text-xs text-slate-400 mt-1">Active noticeboard listings</p>
            </div>
            
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-500">School Replies</span>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 2L4 2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h14l4 4V4a2 2 0 0 0-2-2z" /></svg>
                </div>
                <div class="text-3xl font-bold text-slate-900">${stats.totalReplies.toLocaleString()}</div>
                <p class="text-xs text-slate-400 mt-1">Replies from verified schools</p>
            </div>
        </div>
        
        <!-- School Claims Section -->
        <div class="bg-white rounded-xl shadow-sm border p-6 mb-8">
            <h2 class="text-xl font-bold text-slate-800 mb-4">School Claims</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="text-center p-4 bg-yellow-50 rounded-lg">
                    <div class="text-2xl font-bold text-yellow-700">${stats.claims.pending}</div>
                    <p class="text-sm text-yellow-600">Pending</p>
                </div>
                <div class="text-center p-4 bg-green-50 rounded-lg">
                    <div class="text-2xl font-bold text-green-700">${stats.claims.approved}</div>
                    <p class="text-sm text-green-600">Approved</p>
                </div>
                <div class="text-center p-4 bg-red-50 rounded-lg">
                    <div class="text-2xl font-bold text-red-700">${stats.claims.rejected}</div>
                    <p class="text-sm text-red-600">Rejected</p>
                </div>
            </div>
            <div class="mt-4 text-center">
                <a href="/admin/claims" class="inline-block bg-black hover:bg-slate-800 text-white font-semibold py-2 px-5 rounded-full text-sm transition">See School Claims</a>
            </div>
        </div>
        
        <!-- Flagged Reviews Section -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-4">
            <div class="flex justify-between items-center">
                <h2 class="text-base font-black text-slate-900 tracking-tight">Flagged Reviews</h2>
                <span class="bg-red-100 text-red-700 text-xs font-extrabold px-2 py-1 rounded-full">${stats.flagged.reviews} pending</span>
            </div>
            <div class="mt-3 text-right">
                <a href="/admin/flags" class="inline-block bg-black hover:bg-slate-800 text-white font-semibold py-1.5 px-4 rounded-full text-xs transition">See Flagged Reviews</a>
            </div>
        </div>
        
        <!-- Flagged Replies Section -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-4">
            <div class="flex justify-between items-center">
                <h2 class="text-base font-black text-slate-900 tracking-tight">Flagged Replies</h2>
                <span class="bg-orange-100 text-orange-700 text-xs font-extrabold px-2 py-1 rounded-full">${stats.flagged.replies} pending</span>
            </div>
            <div class="mt-3 text-right">
                <a href="/admin/flags?type=reply" class="inline-block bg-black hover:bg-slate-800 text-white font-semibold py-1.5 px-4 rounded-full text-xs transition">See Flagged Replies</a>
            </div>
        </div>
        
        <!-- Flagged Ads Section -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
            <div class="flex justify-between items-center">
                <h2 class="text-base font-black text-slate-900 tracking-tight">Flagged Ads</h2>
                <span class="bg-amber-100 text-amber-700 text-xs font-extrabold px-2 py-1 rounded-full" id="flaggedAdsCountSpan">0 pending</span>
            </div>
            <div class="mt-3 text-right">
                <a href="/admin/flagged-ads" class="inline-block bg-black hover:bg-slate-800 text-white font-semibold py-1.5 px-4 rounded-full text-xs transition">See Flagged Ads</a>
            </div>
        </div>
        
        <!-- Banned Users Section -->
        <div class="bg-white rounded-xl shadow-sm border p-6 mt-8">
            <h2 class="text-xl font-bold text-slate-800 mb-4">Banned Users</h2>
            <div class="text-center">
                <a href="/admin/banned-users" class="inline-block bg-black hover:bg-slate-800 text-white font-semibold py-2 px-5 rounded-full text-sm transition">View Banned Users</a>
            </div>
        </div>
        
        <div class="mt-6 text-center text-xs text-slate-400">
            Last updated: ${new Date().toLocaleString()}
        </div>
    `;
    
    container.innerHTML = html;
}

async function updateFlaggedAdsCount() {
    try {
        const response = await fetch('/api/admin/flagged-ads-count');
        const data = await response.json();
        const countElement = document.getElementById('flaggedAdsCountSpan');
        if (countElement) {
            countElement.textContent = (data.count || 0) + " pending";
        }
    } catch(e) { console.error(e); }
}

// Load analytics when page loads
document.addEventListener('DOMContentLoaded', () => {
    loadAnalytics();
    updateFlaggedAdsCount();
});
</script>

<%- include('partials/footer') %>
