# Environment Variables for School Sentiment
# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# Application
PORT=3000
BASE_URL=https://schoolsentiment.co.uk
NODE_ENV=production

# Admin
ADMIN_EMAIL=hubzee@proton.me

# Brevo Email API
BREVO_API_KEY=your_brevo_api_key_here
